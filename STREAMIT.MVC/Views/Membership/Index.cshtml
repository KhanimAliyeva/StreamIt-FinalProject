@model IEnumerable<STREAMIT.Business.Dtos.MembershipDtos.GetMembershipDto>  
<!--bread-crumb-->
<div class="iq-breadcrumb">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-sm-12">
                <nav aria-label="breadcrumb" class="text-center">
                    <ol class="breadcrumb justify-content-center text-white mt-0">
                        <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Home</a></li>
                        <li class="breadcrumb-item active">Pricing Plan</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>    <!--bread-crumb-->


<div class="section-padding">
    <div class="container">
        <div class="row gy-4">
            @if (Model == null || !Model.Any())
            {
                <div class="col-12">
                    <div class="alert alert-info">No membership plans available.</div>
                </div>
            }
            else
            {
                foreach (var item in Model)
                {
                    <div class="col-xl-4 col-md-6">
                        <div class="pricing-plan-wrapper h-100 d-flex flex-column border rounded p-3">
                            <div class="pricing-plan-header d-flex justify-content-between align-items-start mb-3" style="background-color: #E50914;">
                                <div class="plan-wrapper">
                                    <h4 class="plan-name mb-1">@item.Name</h4>
                                </div>
                                <div class="pricing-plan-details text-end">
                                    <div class="plan-main-price h3 mb-0">@item.Price.ToString("0.##") <small class="fs-6">AZN</small></div>
                                    <div class="plan-period-time text-muted">/ @item.DurationInDays Days</div>
                                </div>
                            </div>

                            <div class="pricing-details flex-grow-1">
                                <ul class="list-unstyled mb-4">
                                    <li class="d-flex align-items-start mb-2">
                                        <span class="me-2">@(item.HasAds ? "" : "")</span>
                                        @if (!item.HasAds)
                                        {
                                            <i class="ph ph-check text-success me-2"></i>
                                            <span>Ads free movies and shows</span>
                                        }
                                        else
                                        {
                                            <i class="ph ph-x text-danger me-2"></i>
                                            <span>Includes ads</span>
                                        }
                                    </li>
                                    <li class="d-flex align-items-start mb-2">
                                        @if (item.CanDownload)
                                        {
                                            <i class="ph ph-check text-success me-2"></i>
                                            <span>Download movies and shows</span>
                                        }
                                        else
                                        {
                                            <i class="ph ph-x text-muted me-2"></i>
                                            <span class="text-muted">No downloads</span>
                                        }
                                    </li>
                                    <li class="d-flex align-items-start mb-2">
                                        @if (item.MaxDevices > 1)
                                        {
                                            <i class="ph ph-check text-success me-2"></i>
                                            <span>Watch on up to @item.MaxDevices devices</span>
                                        }
                                        else
                                        {
                                            <i class="ph ph-x text-muted me-2"></i>
                                            <span class="text-muted">Watch on only one device</span>
                                        }
                                    </li>
                                    <li class="d-flex align-items-start mb-2">
                                        <i class="ph ph-check text-success me-2"></i>
                                        <span>Streamit Special</span>
                                    </li>
                                    <li class="d-flex align-items-start mb-2">
                                        @if (item.VideoQuality == "HD")
                                        {
                                            <i class="ph ph-check text-success me-2"></i>
                                            <span>HD video quality</span>
                                        }
                                        else
                                        {
                                            <i class="ph ph-x text-muted me-2"></i>
                                            <span class="text-muted">Standard video quality</span>
                                        }
                                    </li>
                                </ul>
                            </div>

                            <div class="pricing-plan-footer mt-3">
                                <a asp-controller="Membership"
                                       asp-action="Checkout"
                                       asp-route-membershipId="@item.Id"
                                       class="btn btn-primary w-100">
                                    Checkout
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
