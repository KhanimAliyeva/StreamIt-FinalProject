@using STREAMIT.Business.Dtos.BlogDtos
@model PagedBlogViewModel

<div class="iq-breadcrumb">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-sm-12">
                <nav aria-label="breadcrumb" class="text-center">
                    <ol class="breadcrumb justify-content-center text-white mt-0">
                        <li class="breadcrumb-item">
                            <a asp-action="Index" asp-controller="Home">Home</a>
                        </li>
                        <li class="breadcrumb-item active">Blogs</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="blog-pagination section-padding">
    <div class="container">
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-3 gy-5">
            @if (Model.Blogs != null && Model.Blogs.Any())
            {
                foreach (var blog in Model.Blogs)
                {
                    <div class="col-lg-4 col-sm-6">
                        <div class="iq-blog-box">
                            <div class="iq-blog-image clearfix">
                                <a asp-action="Detail" asp-controller="Blog" asp-route-id="@blog.Id">
                                    <img src="@blog.ImageUrl" alt="@blog.Title" class="img-fluid w-100 rounded-3" />
                                </a>
                            </div>

                            <div class="iq-blog-detail">
                                <div class="iq-blog-meta d-flex align-item-center flex-wrap">
                                    <ul class="list-inline mb-0">
                                        <li class="posted-by">
                                            <span class="post-date d-flex align-item-center gap-1">
                                                <i class="ph ph-user"></i>
                                                <a>@blog.AuthorName</a>
                                            </span>
                                        </li>
                                        <li class="posted-on">
                                            <span class="post-author d-flex align-item-center gap-1">
                                                <i class="icon icon-calendar-2"></i>
                                                <span>@blog.CreatedDate.ToString("MMMM d, yyyy")</span>
                                            </span>
                                        </li>
                                    </ul>
                                </div>

                                <h4 class="mb-3 blog-heading">
                                    <a asp-action="Detail" asp-controller="Blog" asp-route-id="@blog.Id">
                                        @blog.Title
                                    </a>
                                </h4>

                                <p class="line-count-2">@blog.Description</p>

                                <div>
                                    <a asp-action="Detail"
                                           asp-controller="Blog"
                                           asp-route-id="@blog.Id"
                                           class="btn btn-link blog-readMore p-0 text-capitalize position-relative font-size-14">
                                        <span>Read More</span>
                                        <span><i class="ph ph-caret-right align-middle"></i></span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <p>No blogs found.</p>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="pagination justify-content-center mt-4">
                <ul class="pagination blog-pagination gap-2">

                    <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                        <a class="page-link rounded-3"
                               asp-action="Index"
                               asp-controller="Blog"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-pageSize="@Model.PageSize">
                            <i class="ph ph-caret-left pageicon-lineheight"></i>
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link d-flex justify-content-center pageicon-lineheight rounded-3"
                                   asp-action="Index"
                                   asp-controller="Blog"
                                   asp-route-page="@i"
                                   asp-route-pageSize="@Model.PageSize">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(Model.HasNext ? "" : "disabled")">
                        <a class="page-link rounded-3"
                               asp-action="Index"
                               asp-controller="Blog"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-pageSize="@Model.PageSize">
                            <i class="ph ph-caret-right pageicon-lineheight"></i>
                        </a>
                    </li>

                </ul>
            </div>
        }
    </div>
</div>