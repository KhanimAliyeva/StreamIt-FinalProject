@model STREAMIT.Business.Dtos.BlogDtos.ResultBlogDto

<!--bread-crumb-->
<div class="iq-breadcrumb">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-sm-12">
                <nav aria-label="breadcrumb" class="text-center">
                    <ol class="breadcrumb justify-content-center text-white mt-0">
                        <li class="breadcrumb-item"><a href="../index.html">Home</a></li>
                        <li class="breadcrumb-item active">The Most Anticipated Movies</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>    <!--bread-crumb-->


<div class="section-padding blog-section">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="iq-blog blog-detail">
                    <a asp-action="Detail" asp-controller="Blog" asp-route-id="@Model.Id" class="blog-image d-block overflow-hidden">
                        <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? Url.Content("~/assets/images/blog/blog1.webp") : Model.ImageUrl)" alt="blog-image" class="img-fluid w-100 mb-5">
                    </a>

                    <div class="iq-blog-box">


                        <div class="iq-blogs-meta">
                        <ul class="iq-blogtag list-inline d-flex  align-items-center flex-wrap mb-0 ">
                            <li class="d-flex align-items-center gap-1">
                                <i class="ph ph-user" aria-hidden="true"></i>
                                <span class="ms-1">@Model.AuthorName</span>
                            </li>
                            <li class="d-flex align-items-center gap-1 ms-3">
                                <i class="icon icon-calendar-2" aria-hidden="true"></i>
                                <span class="ms-1">@Model.CreatedDate.ToString("MMMM d, yyyy")</span>
                            </li>
                        </ul>
                    </div>
                    <h3 class="mb-3">@Model.Title</h3>

                    <h6 class="text-white my-3">@Model.Description</h6>

                    <p class="mb-0 blog-gallery-desc">@Model.Description</p>

            </div>
        </div>
    </div>
</div>
</div>


</div>