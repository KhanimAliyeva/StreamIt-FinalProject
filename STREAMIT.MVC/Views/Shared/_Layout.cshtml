                    <style>
    /* Community icon look */
    .community-nav-btn{
        position: relative;
        border: 1px solid rgba(255,255,255,.10);
        background: rgba(255,255,255,.04);
        transition: .18s ease;
    }
    .community-nav-btn:hover{
        border-color: rgba(229,9,20,.45);
        background: rgba(229,9,20,.12);
        box-shadow: 0 0 0 6px rgba(229,9,20,.08);
    }

    /* optional small red dot (notification style) */
    .community-dot{
        position: absolute;
        top: 7px;
        right: 7px;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #e50914;
        box-shadow: 0 0 0 4px rgba(229,9,20,.18);
        display: none; /* default: gizli */
    }

    /* dot göstərmək istəyirsənsə class verəcəyik */
    .community-nav-link.has-dot .community-dot{ display:block; }

    /* Active state: Community səhifəsində qırmızı vurğu */
    .community-nav-link.active .community-nav-btn{
        border-color: rgba(229,9,20,.55);
        background: rgba(229,9,20,.14);
        box-shadow: 0 0 0 6px rgba(229,9,20,.10);
    }


    /* ✅ unread count badge */
  .community-badge-count{
    position:absolute;
    top: -4px;
    right: -4px;
    min-width: 18px;
    height: 18px;
    padding: 0 6px;
    border-radius: 999px;
    background: #e50914;
    color: #fff;
    font-size: 11px;
    font-weight: 800;
    line-height: 18px;
    text-align: center;
    border: 2px solid rgba(14,14,18,.95); /* qara outline */
    box-shadow: 0 0 0 4px rgba(229,9,20,.16);
    pointer-events: none;
  }

  /* btn-inner relative olmalıdır ki badge düzgün otursun */
  .community-nav-btn .btn-inner{
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
</style>
