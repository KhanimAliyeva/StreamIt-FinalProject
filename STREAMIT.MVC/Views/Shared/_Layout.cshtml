                                  <script>
/* ============================
   VIDEO.JS INIT (səndə olan)
   ============================ */
(function () {
  function initVideoJs() {
    if (!window.videojs) return;
    try {
      if (document.getElementById("my-video")) {
        videojs("my-video");
      }
    } catch (e) {
      console.warn("videojs init error", e);
    }
  }

  if (document.readyState === "complete" || document.readyState === "interactive") {
    initVideoJs();
  } else {
    document.addEventListener("DOMContentLoaded", initVideoJs);
  }
})();

/* ============================
   COMMUNITY (unread + mark-read + realtime)
   ============================ */
(function () {
  // 1) Base URL (tək dəfə)
  if (!window.COMMUNITY_API_BASE) window.COMMUNITY_API_BASE = "https://localhost:7108";
  const API_BASE = window.COMMUNITY_API_BASE;

  const GROUP_ID = 1;

  // 2) Token
  async function getAccessToken() {
    try {
      const resp = await fetch("/Community/Token", { credentials: "include" });
      if (!resp.ok) return null;

      let token = (await resp.text()).trim();
      if (!token) return null;

      if (token.startsWith("Bearer ")) token = token.substring(7).trim();
      return token || null;
    } catch {
      return null;
    }
  }

  // 3) Auth-lu fetch (REST üçün)
  async function apiFetch(url, options = {}) {
    const token = await getAccessToken();

    const headers = new Headers(options.headers || {});
    if (token) headers.set("Authorization", `Bearer ${token}`);

    return fetch(url, {
      ...options,
      headers,
      credentials: "include"
    });
  }

  // 4) Badge update
  function badgeEl() {
    return document.querySelector(".community-badge-count");
  }

  async function refreshCommunityUnread() {
    const badge = badgeEl();
    if (!badge) return;

    try {
      const r = await apiFetch(`${API_BASE}/api/community/unread-count?groupId=${GROUP_ID}`);
      if (!r.ok) return;

      const data = await r.json();
      const unread = Number(data.unread || 0);

      if (unread > 0) {
        badge.style.display = "inline-flex";
        badge.textContent = unread > 99 ? "99+" : String(unread);
      } else {
        badge.style.display = "none";
        badge.textContent = "0";
      }
    } catch {
      // ignore
    }
  }

  async function markCommunityRead() {
    try {
      await apiFetch(`${API_BASE}/api/community/mark-read?groupId=${GROUP_ID}`, {
        method: "POST"
      });
    } catch {
      // ignore
    }
    refreshCommunityUnread();
  }

  // global et (community page-dən çağırmaq istəsən)
  window.refreshCommunityUnread = refreshCommunityUnread;
  window.markCommunityRead = markCommunityRead;

  // 5) debounce
  let t = null;
  function refreshUnreadDebounced() {
    clearTimeout(t);
    t = setTimeout(refreshCommunityUnread, 300);
  }

  function isOnCommunityPage() {
    const p = (window.location.pathname || "").toLowerCase();
    return p.startsWith("/community");
  }

  // 6) realtime SignalR
  async function startRealtime() {
    // duplicate start olmasın
    if (window.__communityRealtimeStarted) return;
    window.__communityRealtimeStarted = true;

    if (!window.signalR) {
      console.warn("signalR script not loaded.");
      return;
    }

    const conn = new signalR.HubConnectionBuilder()
      .withUrl(`${API_BASE}/hubs/community`, {
        withCredentials: true,
        accessTokenFactory: async () => await getAccessToken()
      })
      .withAutomaticReconnect()
      .build();

    conn.on("ReceiveMessage", () => {
      if (isOnCommunityPage()) {
        markCommunityRead(); // community-də oxunmuş say
      } else {
        refreshUnreadDebounced(); // başqa səhifələrdə badge yenilə
      }
    });

    conn.onreconnected(() => refreshUnreadDebounced());

    try {
      await conn.start();
      refreshUnreadDebounced();
      window.__communityRealtimeConn = conn;
    } catch (e) {
      console.warn("Community realtime start error:", e);
    }
  }

  // 7) run
  document.addEventListener("DOMContentLoaded", function () {
    refreshCommunityUnread();
    startRealtime();
  });
})();
</script>
