@model List<STREAMIT.Business.Dtos.WatchlistDtos.GetWatchListDto>

<div class="iq-breadcrumb">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-sm-12">
                <nav aria-label="breadcrumb" class="text-center">
                    <ol class="breadcrumb justify-content-center text-white mt-0">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"> Home</a></li>
                        <li class="breadcrumb-item active">Watchlist</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>    <!--bread-crumb-->

<section class="section-padding">
    <div class="container-fluid">
        <div class="col-md-12">
            <div class="border-bottom mb-5 watchlist-tab">
                <div id="item-nav">
                    <div class="item-list-tabs no-ajax css_prefix-tab-lists" id="object-nav">
                        <ul class="nav nav-underline data-search-tab" id="pills-tab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="pills-movie-tab" data-bs-toggle="pill"
                                        data-bs-target="#pills-movie" type="button" role="tab" aria-controls="pills-movie"
                                        aria-selected="true">
                                    Movie
                                </button>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="tab-content" id="pills-tabContent">
                <div class="tab-pane fade active show" id="pills-movie" role="tabpanel" tabindex="0"
                     aria-labelledby="pills-movie-tab">
                    <div class="row gy-4 row-cols-2 row-cols-sm-2 row-cols-md-3 row-cols-lg-3 row-cols-xl-4 row-cols-xxl-5 data-listing">
                      

                        @if (Model == null || Model.Count == 0)
                        {
                            <p class="text-center w-100">No watchlist available.</p>
                        }
                        else
                        {
                            foreach (var x in Model)
                            {
                                <div class="col">
                                    <div class="common_card">
                                        <div class="image-box w-100">
                                            <a asp-controller="Movie" asp-action="Watch" asp-route-id="@x.MovieId" class="d-block">
                                                <img decoding="async" src="@(string.IsNullOrWhiteSpace(x.PosterUrl) ? Url.Content("~/assets/images/media/gameofhero.webp") : x.PosterUrl)" alt="@x.Title" class="img-fluid">
                                            </a>
                                        </div>
                                        <div class="css_prefix-detail-part">
                                            <h6 class="text-capitalize line-count-1 mb-0">
                                                <a asp-controller="Movie" asp-action="Watch" asp-route-id="@x.MovieId" class="color-inherit">
                                                    @x.Title
                                                </a>
                                            </h6>
                                            <button type="button" class="btn in-watchlist btn-secondary watch-list-btn" onclick="toggleWatchlist(@x.MovieId, this)" data-bs-toggle="tooltip" title="Remove from watchlist">
                                                <i class="icon-check-2"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                     
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

<script>
    async function toggleWatchlist(movieId, btn){
      const resp = await fetch("/WatchList/Toggle", {
        method:"POST",
        headers: {"Content-Type":"application/x-www-form-urlencoded"},
        body: new URLSearchParams({ movieId })
      });

      if(resp.status === 401){
        window.location.href = "/Account/Login";
        return;
      }

      if(!resp.ok){
        StreamSwal.error(await resp.text());
        return;
      }

      const data = await resp.json(); // {status:"removed"/"added"}

      if(data.status === "removed"){
        const confirmed = await StreamSwal.confirmDelete('Remove this movie from your watchlist?');
        if(!confirmed) return;
        const col = btn.closest(".col");
        if(col) col.remove();
        StreamSwal.success('Removed from watchlist');
      } else {
        StreamSwal.success('Added to watchlist');
      }
    }
</script>




