@using STREAMIT.MVC.Areas.Admin.ViewModels
@model PagedUserViewModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var startIndex = (Model.CurrentPage > 0 ? (Model.CurrentPage - 1) * Model.PageSize : 0);
}

<div class="content-inner container-fluid pb-0" id="page_layout">
    <div class="row">
        <div class="col-12">
            <div class="streamit-wraper-table">

                <div class="card-header d-flex justify-content-between gap-3 flex-wrap align-items-center mb-4">
                    <h2 class="episode-playlist-title wp-heading-inline">
                        <span class="position-relative">Users List</span>
                    </h2>
                </div>

                <div class="table-view table-space streamit-wraper-table3">
                    <table id="userTable" class="data-tables table custom-table movie_table custom-table-height">
                        <thead>
                            <tr class="text-uppercase">
                                <th>#</th>
                                <th style="width:80px;">Profile</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th style="width:120px;">Role</th>
                                <th style="width:140px;">Membership</th>
                                <th style="width:100px;">Favorites</th>
                                <th style="width:100px;">Reviews</th>
                                <th style="width:100px;">Status</th>
                                <th style="width:120px;">Join Date</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.Users != null && Model.Users.Any())
                            {
                                @foreach (var item in Model.Users.Select((value, index) => new { value, index }))
                                {
                                    var u = item.value;
                                    var favoritesTotal = u.FavoriteMoviesCount;
                                    var reviewsTotal = u.MovieReviewsCount;

                                    <tr>
                                        <td>@(startIndex + item.index + 1)</td>

                                        <td>
                                            <img src="~/assets/images/user/user.jpg"
                                                 class="rounded-2 avatar avatar-55 img-fluid"
                                                 alt="@(string.IsNullOrWhiteSpace(u.Fullname) ? u.UserName : u.Fullname)" />
                                        </td>

                                        <td>@(string.IsNullOrWhiteSpace(u.Fullname) ? u.UserName : u.Fullname)</td>
                                        <td>@u.Email</td>
                                        <td>@(string.IsNullOrWhiteSpace(u.Role) ? "—" : u.Role)</td>
                                        <td>@(string.IsNullOrWhiteSpace(u.MembershipName) ? "None" : u.MembershipName)</td>
                                        <td>@favoritesTotal</td>
                                        <td>@reviewsTotal</td>

                                        <td>
                                            @if (u.EmailConfirmed)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">Pending</span>
                                            }
                                        </td>

                                        <td>@(u.CreatedAt == default ? "—" : u.CreatedAt.ToString("yyyy-MM-dd"))</td>

                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="11" class="text-center">No users found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Page navigation" class="mt-3">
                            <ul class="pagination">
                                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                                    <a class="page-link"
                                           asp-area="Admin"
                                           asp-controller="User"
                                           asp-action="Index"
                                           asp-route-page="@(Model.CurrentPage - 1)">
                                        Previous
                                    </a>
                                </li>

                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link"
                                               asp-area="Admin"
                                               asp-controller="User"
                                               asp-action="Index"
                                               asp-route-page="@i">
                                            @i
                                        </a>
                                    </li>
                                }

                                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link"
                                           asp-area="Admin"
                                           asp-controller="User"
                                           asp-action="Index"
                                           asp-route-page="@(Model.CurrentPage + 1)">
                                        Next
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>

            </div>
        </div>
    </div>
</div>