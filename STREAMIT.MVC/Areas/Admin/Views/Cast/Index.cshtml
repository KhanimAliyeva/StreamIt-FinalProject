@using STREAMIT.MVC.Areas.Admin.ViewModels
@model PagedPersonViewModel

@{
    var startIndex = (Model.CurrentPage > 0 ? (Model.CurrentPage - 1) * Model.PageSize : 0);
}

<div class="content-inner container-fluid pb-0" id="page_layout">
    <div class="row">
        <div class="col-sm-12">
            <div class="streamit-wraper-table">

                <div class="card-header d-flex justify-content-between gap-3 flex-wrap align-items-center mb-4">
                    <h2 class="episode-playlist-title wp-heading-inline">
                        <span class="position-relative">Persons List</span>
                    </h2>

                    <a asp-area="Admin" asp-controller="Cast" asp-action="Create" class="btn btn-primary">
                        <i class="fa-solid fa-plus me-2"></i> Add New
                    </a>
                </div>

                <div class="table-view table-space streamit-wraper-table3">
                    <table id="userTable" class="data-tables table custom-table movie_table custom-table-height">
                        <thead>
                            <tr class="text-uppercase">
                                <th>#</th>
                                <th></th>
                                <th>Image</th>
                                <th>Name</th>
                                <th>Born</th>
                                <th>Popularity</th>
                                <th>Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.Persons != null && Model.Persons.Any())
                            {
                                @foreach (var item in Model.Persons.Select((value, index) => new { value, index }))
                                {
                                    <tr>
                                        <td>@(startIndex + item.index + 1)</td>
                                        <td>
                                            <input type="checkbox" class="form-check-input" />
                                        </td>
                                        <td>
                                            <img src="@(string.IsNullOrWhiteSpace(item.value.ImageUrl) ? Url.Content("~/assets/images/author/ava-monroe.webp") : item.value.ImageUrl)"
                                                 alt="@item.value.Name"
                                                 class="rounded-2 avatar avatar-55 img-fluid" />
                                        </td>
                                        <td>@item.value.Name</td>
                                        <td>@(item.value.Born == default ? "N/A" : item.value.Born.ToString("yyyy-MM-dd"))</td>
                                        <td>@string.Format("{0:0.0}", item.value.Popularity)</td>
                                        <td>
                                            <div class="d-flex align-items-center list-user-action gap-2">
                                                <a asp-area="Admin"
                                                       asp-controller="Cast"
                                                       asp-action="Edit"
                                                       asp-route-id="@item.value.Id"
                                                       class="btn btn-sm btn-icon btn-success-subtle rounded"
                                                       title="Edit">
                                                    <i class="ph ph-pencil-simple fs-6"></i>
                                                </a>

                                                <form asp-area="Admin"
                                                      asp-controller="Cast"
                                                      asp-action="Delete"
                                                      asp-route-id="@item.value.Id"
                                                      method="post"
                                                      class="d-inline"
                                                      onsubmit="return confirm('Are you sure you want to delete this person?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit"
                                                            class="btn btn-sm btn-icon btn-danger-subtle rounded"
                                                            title="Delete">
                                                        <i class="ph ph-trash-simple fs-6"></i>
                                                    </button>
                                                </form>

                                                <a asp-area="Admin"
                                                       asp-controller="Cast"
                                                       asp-action="Details"
                                                       asp-route-id="@item.value.Id"
                                                       class="btn btn-sm btn-icon btn-info-subtle rounded"
                                                       title="View">
                                                    <i class="ph ph-eye fs-6"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center">No persons found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Page navigation" class="mt-3">
                            <ul class="pagination">
                                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                                    <a class="page-link"
                                           asp-area="Admin"
                                           asp-controller="Cast"
                                           asp-action="Index"
                                           asp-route-page="@(Model.CurrentPage - 1)">
                                        Previous
                                    </a>
                                </li>

                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link"
                                               asp-area="Admin"
                                               asp-controller="Cast"
                                               asp-action="Index"
                                               asp-route-page="@i">
                                            @i
                                        </a>
                                    </li>
                                }

                                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link"
                                           asp-area="Admin"
                                           asp-controller="Cast"
                                           asp-action="Index"
                                           asp-route-page="@(Model.CurrentPage + 1)">
                                        Next
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>

                @if (ViewBag.DebugStatusCode != null)
                {
                    <div class="mt-3 alert alert-warning">
                        <strong>API Debug:</strong> Status Code: @ViewBag.DebugStatusCode
                        <pre class="mt-2">@ViewBag.RawResponse</pre>
                    </div>
                }
            </div>
        </div>
    </div>
</div>