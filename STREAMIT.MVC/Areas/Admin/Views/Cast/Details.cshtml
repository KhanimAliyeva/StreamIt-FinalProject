@model STREAMIT.Business.Dtos.PersonDtos.GetPersonDto?

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Person Details";
}

<div class="container py-4">
    <div class="row">
        @if (Model == null)
        {
            <div class="alert alert-warning">Person not found or API returned an error.</div>
            @if (ViewBag.DebugStatusCode != null)
            {
                <div class="mt-2 alert alert-info">
                    <strong>API Debug:</strong> Status Code: @ViewBag.DebugStatusCode
                    <pre>@ViewBag.RawResponse</pre>
                </div>
            }
            return;
        }
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <img src="@(!string.IsNullOrWhiteSpace(Model.ImageUrl) ? Model.ImageUrl : Url.Content("~/assets/images/author/ava-monroe.webp"))" alt="Person Image" class="img-fluid rounded mb-3" style="max-height:300px; object-fit:cover;" />
                    <h4 class="card-title">@Model.Name</h4>
                    <p class="text-muted mb-1">Gender: @Model.Gender</p>
                    <p class="text-muted mb-1">Role: @Model.Role</p>
                    <p class="text-muted mb-1">Born: @Model.Born.ToString("yyyy-MM-dd")</p>
                    <p class="text-muted mb-3">Died: @(Model.Died.HasValue ? Model.Died.Value.ToString("yyyy-MM-dd") : "-")</p>

                    <div class="d-flex justify-content-center gap-2">
                        <a asp-area="Admin" asp-controller="Cast" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-primary">Edit</a>

                        <form asp-area="Admin" asp-controller="Cast" asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Delete this person?');" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>

                        <a asp-area="Admin" asp-controller="Cast" asp-action="Index" class="btn btn-sm btn-secondary">Back to list</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h5 class="mb-3">Biography</h5>
                    <p>@(string.IsNullOrWhiteSpace(Model.Biography) ? "No biography provided." : Model.Biography)</p>

                    <hr />

                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="mb-1">Popularity</h6>
                            <p>@Model.Popularity</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="mb-1">Additional Info</h6>
                            <p>--</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
