@model STREAMIT.Business.Dtos.LanguageDtos.CreateLanguageDto

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Create Language";
}

<div class="content-inner container-fluid pb-0" id="page_layout">
    <div class="row">
        <div class="col-lg-6">
            <div class="card">

                <div class="card-header">
                    <h2 class="episode-playlist-title wp-heading-inline">
                        <span class="position-relative"> Add New Language </span>
                    </h2>
                </div>

                <div class="card-body">
                    <form asp-area="Admin"
                          asp-controller="Language"
                          asp-action="Create"
                          method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Name -->
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" placeholder="Enter language name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <!-- Code -->
                        <div class="mb-3">
                            <label asp-for="Code" class="form-label"></label>
                            <input asp-for="Code" class="form-control" placeholder="Enter language code (e.g. en, az, tr)" />
                            <span asp-validation-for="Code" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-area="Admin"
                                   asp-controller="Language"
                                   asp-action="Index"
                                   class="btn btn-secondary">
                                Cancel
                            </a>

                            <button type="submit" class="btn btn-primary">
                                <i class="fa-solid fa-check me-2"></i> Create
                            </button>
                        </div>

                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

