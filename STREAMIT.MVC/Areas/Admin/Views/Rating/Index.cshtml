@using STREAMIT.MVC.Areas.Admin.ViewModels
@model PagedRatingViewModel

@{
    var currentFilter = Context.Request.Query["filterCategory"].ToString();
    var startIndex = (Model.CurrentPage > 0 ? (Model.CurrentPage - 1) * Model.PageSize : 0);
}

<div class="content-inner container-fluid pb-0" id="page_layout">
    <div class="row">
        <div class="col-sm-12">
            <div class="streamit-wraper-table">
                <div class="card-header d-flex justify-content-between gap-3 flex-wrap align-items-center mb-4">
                    <h2 class="episode-playlist-title wp-heading-inline">
                        <span class="position-relative">Review list</span>
                    </h2>
                </div>

                <div class="table-view table-space streamit-wraper-table3">
                    <div class="d-flex align-items-center mt-3 gap-2">
                        <form asp-action="Index" method="get" class="d-flex gap-2">
                            <select class="form-control select2-basic-multiple" name="filterCategory">
                                <option value="" selected="@(string.IsNullOrEmpty(currentFilter))">All</option>
                                <option value="Movie" selected="@(currentFilter == "Movie")">Movie</option>
                            </select>
                            <button type="submit" class="btn btn-primary">Filter</button>
                        </form>
                    </div>

                    <table id="seasonTable" class="data-tables table custom-table movie_table custom-table-height" >
                        <thead>
                            <tr class="text-uppercase">
                                <th>Id</th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Release Year</th>
                                <th>Rating</th>
                                <th>Comment</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Reviews.Select((value, index) => new { value, index }))
                            {
                                <tr>
                                    <td>@(startIndex + item.index + 1)</td>
                                    <td>@item.value.Name</td>
                                    <td>@item.value.Category</td>
                                    <td>@item.value.ReleaseYear</td>
                                    <td>@item.value.Rating</td>
                                    <td>@(item.value.Comment?.Length > 50 ? item.value.Comment.Substring(0, 50) + "..." : item.value.Comment)</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Page navigation" class="mt-3">
                            <ul class="pagination">
                                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                                    <a class="page-link"
                                           asp-action="Index"
                                           asp-route-filterCategory="@currentFilter"
                                           asp-route-page="@(Model.CurrentPage - 1)">
                                        Previous
                                    </a>
                                </li>

                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link"
                                               asp-action="Index"
                                               asp-route-filterCategory="@currentFilter"
                                               asp-route-page="@i">
                                            @i
                                        </a>
                                    </li>
                                }

                                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link"
                                           asp-action="Index"
                                           asp-route-filterCategory="@currentFilter"
                                           asp-route-page="@(Model.CurrentPage + 1)">
                                        Next
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </div>
    </div>
</div>