@model STREAMIT.Business.Dtos.MovieDtos.UpdateMovieDto
@using Microsoft.AspNetCore.Mvc.Rendering

<div class="container py-5">
    <h2 class="mb-4 text-primary">Edit Movie</h2>

    <form asp-area="Admin" asp-controller="Movie" asp-action="Update" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">

            <!-- Left Column -->
            <div class="col-lg-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Movie Info</h5>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Title</label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Content" class="form-label">Content</label>
                            <textarea asp-for="Content" class="form-control" rows="6"></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="ReleaseDate" class="form-label">Release Date</label>
                                <input asp-for="ReleaseDate" type="datetime-local" class="form-control" />
                                <span asp-validation-for="ReleaseDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Duration" class="form-label">Duration</label>
                                <input asp-for="Duration" type="number" step="0.1" class="form-control" />
                                <span asp-validation-for="Duration" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-3">
                            <div class="col-md-6">
                                <label asp-for="MembershipId" class="form-label">Membership</label>
                                <select asp-for="MembershipId" class="form-select" asp-items="ViewBag.Memberships"></select>
                                <span asp-validation-for="MembershipId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LanguageId" class="form-label">Language</label>
                                <select asp-for="LanguageId" class="form-select" asp-items="ViewBag.Languages"></select>
                                <span asp-validation-for="LanguageId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-3">
                            <div class="col-md-6">
                                <label class="form-label">Genres</label>
                                <select asp-for="GenreIds" asp-items="ViewBag.Genres" multiple class="form-select"></select>
                                <span asp-validation-for="GenreIds" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Tags</label>
                                <select asp-for="TagIds" asp-items="ViewBag.Tags" multiple class="form-select"></select>
                                <span asp-validation-for="TagIds" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-3">
                            <label class="form-label">People (Cast/Crew)</label>
                            <select asp-for="PersonIds" asp-items="ViewBag.People" multiple class="form-select"></select>
                            <span asp-validation-for="PersonIds" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column -->
            <div class="col-lg-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Media & Status</h5>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option value="Published">Published</option>
                                <option value="Draft">Draft</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Poster" class="form-label">Poster</label>
                            <input asp-for="Poster" type="file" class="form-control" />
                            <span asp-validation-for="Poster" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="YoutubeUrl" class="form-label">YouTube URL</label>
                            <input asp-for="YoutubeUrl" type="text" class="form-control" />
                            <span asp-validation-for="YoutubeUrl" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Movie" class="form-label">Movie File</label>
                            <input asp-for="Movie" type="file" class="form-control" />
                            <span asp-validation-for="Movie" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="offcanvas-footer border-top">
            <div class="d-flex gap-3 p-3">
                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-outline-primary" data-bs-dismiss="offcanvas">Close</button>
            </div>
        </div>
    </form>
</div>