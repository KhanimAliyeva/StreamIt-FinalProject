@using STREAMIT.MVC.Areas.Admin.ViewModels
@model PagedGenreViewModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Genres";
    var startIndex = (Model.CurrentPage > 0 ? (Model.CurrentPage - 1) * Model.PageSize : 0);
}

<div class="content-inner container-fluid pb-0" id="page_layout">
    <div class="row">
        <div class="col-sm-12">
            <div class="streamit-wraper-table">

                <div class="card-header d-flex justify-content-between gap-3 flex-wrap align-items-center mb-4">
                    <h2 class="episode-playlist-title wp-heading-inline">
                        <span class="position-relative">Genres</span>
                    </h2>

                    <a asp-area="Admin" asp-controller="Genre" asp-action="Create" class="btn btn-primary">
                        <i class="fa-solid fa-plus me-2"></i> Add Genre
                    </a>
                </div>

                @if (TempData["DeleteError"] != null)
                {
                    <div class="alert alert-danger mb-3">
                        @TempData["DeleteError"]
                    </div>
                }

                <div class="table-view table-space streamit-wraper-table3">
                    <table class="data-tables table custom-table movie_table custom-table-height">
                        <thead>
                            <tr class="text-uppercase">
                                <th>#</th>
                                <th>Name</th>
                                <th>Movies Count</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Genres != null && Model.Genres.Any())
                            {
                                @foreach (var item in Model.Genres.Select((value, index) => new { value, index }))
                                {
                                    <tr>
                                        <td>@(startIndex + item.index + 1)</td>
                                        <td>@item.value.Name</td>
                                        <td>@item.value.MovieCount</td>
                                        <td>
                                            <div class="d-flex align-items-center list-user-action gap-2">
                                                <a asp-area="Admin"
                                                       asp-controller="Genre"
                                                       asp-action="Edit"
                                                       asp-route-id="@item.value.Id"
                                                       class="btn btn-sm btn-icon btn-success-subtle rounded"
                                                       title="Edit">
                                                    <i class="ph ph-pencil-simple fs-6"></i>
                                                </a>

                                                <form asp-area="Admin"
                                                      asp-controller="Genre"
                                                      asp-action="Delete"
                                                      asp-route-id="@item.value.Id"
                                                      method="post"
                                                      class="d-inline"
                                                      onsubmit="return confirm('Are you sure you want to delete this genre?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit"
                                                            class="btn btn-sm btn-icon btn-danger-subtle rounded"
                                                            title="Delete">
                                                        <i class="ph ph-trash-simple fs-6"></i>
                                                    </button>
                                                </form>

                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center">No genres found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Page navigation" class="mt-3">
                            <ul class="pagination">
                                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                                    <a class="page-link"
                                           asp-area="Admin"
                                           asp-controller="Genre"
                                           asp-action="Index"
                                           asp-route-page="@(Model.CurrentPage - 1)">
                                        Previous
                                    </a>
                                </li>

                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link"
                                               asp-area="Admin"
                                               asp-controller="Genre"
                                               asp-action="Index"
                                               asp-route-page="@i">
                                            @i
                                        </a>
                                    </li>
                                }

                                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link"
                                           asp-area="Admin"
                                           asp-controller="Genre"
                                           asp-action="Index"
                                           asp-route-page="@(Model.CurrentPage + 1)">
                                        Next
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>

            </div>
        </div>
    </div>
</div>