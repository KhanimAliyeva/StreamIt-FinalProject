@model STREAMIT.Business.Dtos.DashboardDtos.GetDashboardDto
@using System.Text.Json

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    .dashboard-card,
    .chart-card {
        background: #111;
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 16px;
        padding: 24px;
        color: #fff;
        height: 100%;
    }

    .dashboard-card {
        min-height: 180px;
    }

    .dashboard-icon {
        font-size: 32px;
        margin-bottom: 24px;
        display: inline-block;
    }

    .dashboard-number {
        font-size: 36px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .dashboard-title {
        color: #ccc;
        font-size: 17px;
    }

    .chart-wrap {
        position: relative;
        height: 320px;
    }

    .section-title {
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 18px;
        color: #fff;
    }
</style>

<div class="container-fluid py-4">
    <div class="row g-4">

        <div class="col-md-6 col-xl-3">
            <div class="dashboard-card">
                <i class="bi bi-people dashboard-icon"></i>
                <div class="dashboard-number">@Model.TotalUsers</div>
                <div class="dashboard-title">Total Users</div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="dashboard-card">
                <i class="bi bi-person-check dashboard-icon"></i>
                <div class="dashboard-number">@Model.ActiveUsers</div>
                <div class="dashboard-title">Active Users</div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="dashboard-card">
                <i class="bi bi-credit-card dashboard-icon"></i>
                <div class="dashboard-number">@Model.TotalSubscribers</div>
                <div class="dashboard-title">Subscribers</div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="dashboard-card">
                <i class="bi bi-film dashboard-icon"></i>
                <div class="dashboard-number">@Model.TotalMovies</div>
                <div class="dashboard-title">Movies</div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="dashboard-card">
                <i class="bi bi-chat-left-text dashboard-icon"></i>
                <div class="dashboard-number">@Model.TotalReviews</div>
                <div class="dashboard-title">Reviews</div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="dashboard-card">
                <i class="bi bi-heart dashboard-icon"></i>
                <div class="dashboard-number">@Model.TotalFavorites</div>
                <div class="dashboard-title">Favorites</div>
            </div>
        </div>

        <div class="col-md-12 col-xl-4">
            <div class="dashboard-card">
                <i class="bi bi-person-plus dashboard-icon"></i>
                <div class="dashboard-number">@Model.NewUsersThisMonth</div>
                <div class="dashboard-title">New Users This Month</div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="chart-card">
                <div class="section-title">Top Genres</div>
                <div class="chart-wrap">
                    <canvas id="genreChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="chart-card">
                <div class="section-title">New User Registrations</div>
                <div class="chart-wrap">
                    <canvas id="userChart"></canvas>
                </div>
            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const genreLabels = @Html.Raw(JsonSerializer.Serialize(Model.GenreLabels));
    const genreCounts = @Html.Raw(JsonSerializer.Serialize(Model.GenreCounts));

    const userLabels = @Html.Raw(JsonSerializer.Serialize(Model.UserLabels));
    const userCounts = @Html.Raw(JsonSerializer.Serialize(Model.UserCounts));


    new Chart(document.getElementById('genreChart'), {
    type: 'doughnut',
    data: {
    labels: genreLabels,
    datasets: [{
    data: genreCounts,
    backgroundColor: ['#ff1e1e', '#d10000', '#a50000', '#7d0000', '#550000'],
    borderWidth: 0
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false,
    cutout: '65%',
    plugins: {
    legend: {
    position: 'bottom',
    labels: {
    color: '#fff'
    }
    }
    }
    }
    });

    new Chart(document.getElementById('userChart'), {
    type: 'bar',
    data: {
    labels: userLabels,
    datasets: [{
    label: 'Users',
    data: userCounts,
    backgroundColor: '#ff1e1e',
    borderRadius: 8
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
    legend: {
    labels: { color: '#fff' }
    }
    },
    scales: {
    x: {
    ticks: { color: '#ccc' },
    grid: { display: false }
    },
    y: {
    ticks: { color: '#ccc' },
    grid: { color: 'rgba(255,255,255,.05)' }
    }
    }
    }
    });
</script>