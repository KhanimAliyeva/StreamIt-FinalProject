<div class="iq-banner-thumb-slider overflow-hidden">
    <div class="slider">
        <div class="position-relative slider-bg my-auto">

            <div class="horizontal_thumb_slider" data-swiper="slider-thumbs-ott">
                <div class="banner-thumb-slider-nav">
                    <div class="swiper-container" data-swiper="slider-thumbs-inner-ott">
                        <div class="swiper-wrapper">
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    var coverUrl = string.IsNullOrWhiteSpace(item.CoverImageUrl)
                                        ? Url.Content("~/assets/images/default-cover.jpg")
                                        : Url.Content("~/" + item.CoverImageUrl.TrimStart('/'));

                                    <div class="swiper-slide swiper-bg">
                                        <div class="block-images position-relative">
                                            <div class="img-box">
                                                <img src="@item.CoverImageUrl"
                                                     class="img-fluid"
                                                     alt="@item.Title"
                                                     loading="lazy" />

                                                <div class="block-description">
                                                    <h6 class="iq-title fw-500 line-count-1">@item.Title</h6>

                                                    <div class="d-flex align-items-center gap-1">
                                                        <i class="ph ph-film-strip"></i>
                                                        <span class="fs-12">Movie</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="swiper-slide swiper-bg">
                                    <div class="block-images position-relative">
                                        <div class="img-box">
                                            <img src="~/assets/images/default-cover.jpg" class="img-fluid" alt="No slides" />
                                            <div class="block-description">
