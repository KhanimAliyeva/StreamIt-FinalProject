@model IEnumerable<STREAMIT.Business.Dtos.RatingDtos.RatingDto>

<div class="content-inner container-fluid pb-0" id="page_layout">
    <div class="row">
        <div class="col-sm-12">
            <div class="streamit-wraper-table">
                <div class="card-header d-flex justify-content-between gap-3 flex-wrap align-items-center mb-4">
                    <h2 class="episode-playlist-title wp-heading-inline">
                        <span class="position-relative">Review list</span>
                    </h2>
                </div>

                <div class="table-view table-space streamit-wraper-table3">
                    <div class="d-flex align-items-center mt-3 gap-2">
                        <form asp-action="Index" method="get" class="d-flex gap-2">
                            <select class="form-control select2-basic-multiple" name="filterCategory">
                                <option value="">All</option>
                                <option value="Movie">Movie</option>
                                <option value="TvShow">Tv Show</option>
                                <option value="Video">Video</option>
                            </select>
                            <button type="submit" class="btn btn-primary">Filter</button>
                        </form>
                    </div>

                    <table id="seasonTable" class="data-tables table custom-table movie_table custom-table-height" data-toggle="data-table2">
                        <thead>
                            <tr class="text-uppercase">
                                <th>#</th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Release Year</th>
                                <th>Rating</th>
                                <th>Comment</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Select((value, index) => new { value, index }))
                            {
                                <tr>
                                    <td>@(item.index + 1)</td>
                                    <td>@item.value.Name</td>
                                    <td>@item.value.Category</td>
                                    <td>@item.value.ReleaseYear</td>
                                    <td>@item.value.Rating</td>
                                    <td>@(item.value.Comment.Length > 50 ? item.value.Comment.Substring(0, 50) + "..." : item.value.Comment)</td>
                                    <td>
                                        <div class="d-flex align-items-center list-user-action gap-2">
                                            <a asp-action="Delete" asp-route-id="@item.value.Id" class="d-inline">
                                                    <i class="ph ph-trash-simple fs-6"></i>
                                            </a>
                                            
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>