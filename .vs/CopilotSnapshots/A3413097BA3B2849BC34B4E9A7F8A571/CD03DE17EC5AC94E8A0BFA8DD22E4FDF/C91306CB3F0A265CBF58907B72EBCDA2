@model STREAMIT.Business.Dtos.TvShowDtos.UpdateTvShowDto
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <h2 class="mb-4 text-primary">Update TV Show</h2>

    <form asp-area="Admin" asp-controller="TvShow" asp-action="Update" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">
            @{
                var genresList = ViewBag.Genres as IEnumerable<object> ?? System.Linq.Enumerable.Empty<object>();
                var tagsList = ViewBag.Tags as IEnumerable<object> ?? System.Linq.Enumerable.Empty<object>();
                var peopleList = ViewBag.People as IEnumerable<object> ?? System.Linq.Enumerable.Empty<object>();
                var languagesList = ViewBag.Languages as IEnumerable<object> ?? System.Linq.Enumerable.Empty<object>();
                var membershipsList = ViewBag.Memberships as IEnumerable<object> ?? System.Linq.Enumerable.Empty<object>();
            }
            <div class="col-lg-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">TV Show Info</h5>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Title</label>
                            <input asp-for="Title" class="form-control" placeholder="Enter title" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Content" class="form-label">Content</label>
                            <textarea asp-for="Content" class="form-control" rows="6" placeholder="Description..."></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="ReleaseDate" class="form-label">Release Date</label>
                                <input asp-for="ReleaseDate" type="date" class="form-control" />
                                <span asp-validation-for="ReleaseDate" class="text-danger"></span>
                            </div>
                            
                        </div>

                        <div class="row g-3 mt-3">
                            <div class="col-md-6">
                                <label asp-for="MembershipId" class="form-label"></label>
                                <select asp-for="MembershipId" class="form-select" asp-items="@(new SelectList(ViewBag.Memberships, "Id", "Name", Model.MembershipId))">
                                    <option value="0">-- Select Membership --</option>
                                </select>
                                <span asp-validation-for="MembershipId" class="text-danger"></span>
                            </div>


                         

                            <div class="col-md-6">
                                <label asp-for="LanguageId" class="form-label"></label>
                                <select asp-for="LanguageId" class="form-select" asp-items="@(new SelectList(ViewBag.Languages, "Id", "Name", Model.LanguageId))">
                                    <option value="0">-- Select Language --</option>
                                </select>
                                <span asp-validation-for="LanguageId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-3">
                            <div class="col-md-6">
                                <label class="form-label">Genres</label>
                                <select asp-for="GenreIds" asp-items="@(new MultiSelectList(ViewBag.Genres, "Id", "Name", Model.GenreIds))" multiple></select>

                                <span asp-validation-for="GenreIds" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Tags</label>
                                <select asp-for="TagIds" asp-items="@(new MultiSelectList(ViewBag.Tags, "Id", "Name", Model.TagIds))" multiple></select>
                                <span asp-validation-for="TagIds" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-3">
                            <label class="form-label">People</label>
                            <select asp-for="PersonIds" asp-items="@(new MultiSelectList(ViewBag.People, "Id", "Name", Model.PersonIds))" multiple></select>
                            <span asp-validation-for="PersonIds" class="text-danger"></span>
                        </div>

                        <div class="mt-4">
                            <h5 class="mb-2">Seasons & Episodes</h5>
                            <div id="seasons-container"></div>
                            <div class="mt-2">
                                <button type="button" id="add-season" class="btn btn-sm btn-outline-primary">Add Season</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Media & Status</h5>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Published">Published</option>
                                <option value="Draft">Draft</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PosterUrl" class="form-label">Poster </label>
                            <input asp-for="PosterUrl" type="file" class="form-control" />
                            <span asp-validation-for="PosterUrl" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="YoutubeUrl" class="form-label">Trailer URL</label>
                            <input asp-for="YoutubeUrl" class="form-control" />
                            <span asp-validation-for="YoutubeUrl" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="offcanvas-footer border-top">
            <div class="d-flex gap-3 p-3">
                <button type="submit" class="btn btn-primary d-flex align-items-center gap-2">
                    <i class="ph-fill ph-floppy-disk-back"></i>Save
                </button>
                <a asp-area="Admin" asp-controller="TvShow" asp-action="Index" class="btn btn-outline-primary d-flex align-items-center gap-2">Cancel</a>
            </div>
        </div>
    </form>
</div>

<!-- Templates for dynamic seasons/episodes -->
<div id="season-template" style="display:none">
    <div class="card mb-3 season" data-index="__SID__">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6>Season <span class="season-number-display">__SNUM__</span></h6>
                <div>
                    <button type="button" class="btn btn-sm btn-outline-success add-episode">Add Episode</button>
                    <button type="button" class="btn btn-sm btn-outline-danger remove-season">Remove Season</button>
                </div>
            </div>

            <div class="mb-2">
                <label class="form-label">Season Number</label>
                <input name="Seasons[__SID__].SeasonNumber" class="form-control season-number" value="1" />
            </div>

            <div class="episodes-container">
                <!-- episodes will be appended here -->
            </div>
        </div>
    </div>
</div>

<div id="episode-template" style="display:none">
    <div class="card mb-2 episode" data-ep-index="__EID__">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6>Episode <span class="ep-number-display">__ENUM__</span></h6>
                <button type="button" class="btn btn-sm btn-outline-danger remove-episode">Remove Episode</button>
            </div>
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Episode #</label>
                    <input name="Seasons[__SID__].Episodes[__EID__].EpisodeNumber" class="form-control ep-number" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Title</label>
                    <input name="Seasons[__SID__].Episodes[__EID__].Title" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Duration (min)</label>
                    <input name="Seasons[__SID__].Episodes[__EID__].Duration" class="form-control" type="number" step="0.1" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Video</label>
                    <input name="Seasons[__SID__].Episodes[__EID__].Video" type="file" class="form-control" />
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function(){
        let seasonCount = 0;

        function addSeason() {
            const sTemplate = document.getElementById('season-template').innerHTML;
            const html = sTemplate.replace(/__SID__/g, seasonCount).replace(/__SNUM__/g, seasonCount + 1);
            const container = document.createElement('div');
            container.innerHTML = html;
            const seasonEl = container.firstElementChild;

            // add first episode by default
            addEpisodeToSeason(seasonEl, 0);

            // wire buttons
            seasonEl.querySelector('.add-episode').addEventListener('click', () => {
                const epCount = seasonEl.querySelectorAll('.episode').length;
                addEpisodeToSeason(seasonEl, epCount);
            });

            seasonEl.querySelector('.remove-season').addEventListener('click', () => seasonEl.remove());

            seasonEl.querySelector('.season-number').addEventListener('input', (e) => {
                seasonEl.querySelector('.season-number-display').textContent = e.target.value;
            });

            document.getElementById('seasons-container').appendChild(seasonEl);
            seasonCount++;
        }

        function addEpisodeToSeason(seasonEl, epIndex) {
            const sIndex = seasonEl.getAttribute('data-index');
            const epTemplate = document.getElementById('episode-template').innerHTML
                .replace(/__SID__/g, sIndex)
                .replace(/__EID__/g, epIndex)
                .replace(/__ENUM__/g, epIndex + 1);

            const div = document.createElement('div');
            div.innerHTML = epTemplate;
            const epEl = div.firstElementChild;

            epEl.querySelector('.remove-episode').addEventListener('click', () => epEl.remove());

            seasonEl.querySelector('.episodes-container').appendChild(epEl);
        }

        document.getElementById('add-season').addEventListener('click', addSeason);

        // initialize with one season
        addSeason();
    })();
</script>
