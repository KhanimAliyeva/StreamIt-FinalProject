using Microsoft.AspNetCore.Mvc;
using Microsoft.AspNetCore.Mvc.Rendering;
using Newtonsoft.Json;
using STREAMIT.Business.Dtos;
using STREAMIT.Business.Dtos.GenreDtos;
using STREAMIT.Business.Dtos.LanguageDtos;
using STREAMIT.Business.Dtos.MembershipDtos;
using STREAMIT.Business.Dtos.PersonDtos;
using STREAMIT.Business.Dtos.ResultDtos;
using STREAMIT.Business.Dtos.TagDtos;
using STREAMIT.Business.Dtos.TvShowDtos;
using System.Net.Http.Headers;
using System.Net.Http.Json;

namespace STREAMIT.MVC.Areas.Admin.Controllers
{
    [Area("Admin")]
    public class TvShowController : Controller
    {
        private readonly HttpClient _httpClient;

        public TvShowController(IHttpClientFactory factory)
        {
            _httpClient = factory.CreateClient("ApiClient");
        }

        #region INDEX
        public async Task<IActionResult> Index()
        {
            var tvShows = await SafeGetListFromApi<GetTvShowDto>("api/TvShow");
            return View(tvShows);
        }
        #endregion

        #region CREATE
        public async Task<IActionResult> Create()
        {
            await LoadDropdowns();
            return View(new CreateTvShowDto());
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> Create(CreateTvShowDto dto)
        {
            if (!ModelState.IsValid)
            {
                await LoadDropdowns(dto);
                return View(dto);
            }

            using var content = BuildMultipartContent(dto);

            var response = await _httpClient.PostAsync("api/TvShow", content);
            var respText = await response.Content.ReadAsStringAsync();

            if (!response.IsSuccessStatusCode)
            {
                await LoadDropdowns(dto);
                var error = await SafeReadJson<ResultDto>(response);
                ModelState.AddModelError("", error?.Message ?? respText);
                return View(dto);
            }

            return RedirectToAction(nameof(Index));
        }
        #endregion

        #region UPDATE
        public async Task<IActionResult> Update(int id)
        {
            var tvShow = await SafeGetFromApi<GetTvShowDto>($"api/TvShow/{id}");
            if (tvShow == null) return BadRequest();

            var allTags = await SafeGetListFromApi<TagDto>("Tag");
            var allGenres = await SafeGetListFromApi<GenreDto>("Genre");
            var allPeople = await SafeGetListFromApi<PersonDto>("Person");
            var allMemberships = await SafeGetListFromApi<MembershipDto>("Membership");
            var allLanguages = await SafeGetListFromApi<LanguageDto>("Language");

            var dto = new UpdateTvShowDto
            {
                Id = tvShow.Id,
                Title = tvShow.Title,
                Status = tvShow.Status,
                Content = tvShow.Content,
                YoutubeUrl = tvShow.YoutubeUrl,
                ReleaseDate = tvShow.ReleaseDate,
                MembershipId = tvShow.MembershipId,
                LanguageId = tvShow.LanguageId,
                TagIds = tvShow.TagIds ?? new List<int>(),
                PersonIds = tvShow.People?.Select(p => p.Id).ToList() ?? new List<int>(),
                Seasons = tvShow.Seasons?.Select(s => new CreateSeasonDto
                {
                    SeasonNumber = s.SeasonNumber,
                    Episodes = s.Episodes?.Select(ep => new CreateEpisodeDto
                    {
                        EpisodeNumber = ep.EpisodeNumber,
                        Title = ep.Title,
                        Duration = (float)ep.Duration
                    }).ToList() ?? new List<CreateEpisodeDto>()
                }).ToList() ?? new List<CreateSeasonDto>()
            };

            ViewBag.RawTvShowJson = JsonConvert.SerializeObject(tvShow);

            await LoadDropdowns(dto);
            return View(dto);
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> Update(UpdateTvShowDto dto)
        {
            if (!ModelState.IsValid)
            {
                await LoadDropdowns(dto); // ✅ dto göndər ki dropdownlar işləsin
                return View(dto);
            }

            using var content = BuildMultipartContent(dto, true);

            var response = await _httpClient.PutAsync($"api/TvShow/{dto.Id}", content);
            if (!response.IsSuccessStatusCode)
            {
                await LoadDropdowns(dto);
                var error = await SafeReadJson<ResultDto>(response);
                ModelState.AddModelError("", error?.Message ?? "Something went wrong...");
                return View(dto);
            }

            return RedirectToAction(nameof(Index));
        }
        #endregion

        #region DETAILS
        public async Task<IActionResult> Details(int id)
        {
            var tvShow = await SafeGetFromApi<GetTvShowDto>($"api/TvShow/{id}");
            if (tvShow == null) return BadRequest();
            return View(tvShow);
        }
        #endregion

        #region DELETE
        public async Task<IActionResult> Delete(int id)
        {
            try
            {
                var response = await _httpClient.DeleteAsync($"api/TvShow/{id}");
                if (!response.IsSuccessStatusCode)
                {
                    var error = await SafeReadJson<ResultDto>(response);
                    return NotFound(error?.Message ?? "Something went wrong...");
                }

                return RedirectToAction(nameof(Index));
            }
            catch (Exception ex)
            {
                // istəsən log edə bilərsən
                return BadRequest(ex.Message);
            }
        }
        #endregion

        #region HELPERS

        private async Task<List<T>> SafeGetListFromApi<T>(string endpoint)
        {
            try
            {
                var url = endpoint.StartsWith("api/", StringComparison.OrdinalIgnoreCase) ? endpoint : $"api/{endpoint}";
                var response = await _httpClient.GetAsync(url);
                if (!response.IsSuccessStatusCode) return new List<T>();

                var content = await response.Content.ReadAsStringAsync();
                if (string.IsNullOrWhiteSpace(content)) return new List<T>();

                return JsonConvert.DeserializeObject<List<T>>(content) ?? new List<T>();
            }
            catch { return new List<T>(); }
        }

        private async Task<T?> SafeGetFromApi<T>(string endpoint)
        {
            try
            {
                var response = await _httpClient.GetAsync(endpoint);
                if (!response.IsSuccessStatusCode) return default;

                var content = await response.Content.ReadAsStringAsync();
                if (string.IsNullOrWhiteSpace(content)) return default;

                // ResultDto<T> və ya raw object
                try
                {
                    var result = JsonConvert.DeserializeObject<ResultDto<T>>(content);
                    if (result != null && result.Data != null)
                        return result.Data;
                }
                catch { }

                return JsonConvert.DeserializeObject<T>(content);
            }
            catch { return default; }
        }

        private async Task<T?> SafeReadJson<T>(HttpResponseMessage response)
        {
            try { return await response.Content.ReadFromJsonAsync<T>(); }
            catch { return default; }
        }

        private async Task LoadDropdowns(object? dto = null)
        {
            var allMemberships = await SafeGetListFromApi<MembershipDto>("Membership");
            var allLanguages = await SafeGetListFromApi<LanguageDto>("Language");
            var allGenres = await SafeGetListFromApi<GenreDto>("Genre");
            var allTags = await SafeGetListFromApi<TagDto>("Tag");
            var allPeople = await SafeGetListFromApi<PersonDto>("Person");

            int membershipId = 0;
            int languageId = 0;
            List<int> genreIds = new List<int>();
            List<int> tagIds = new List<int>();
            List<int> personIds = new List<int>();

            if (dto is UpdateTvShowDto u)
            {
                membershipId = u.MembershipId;
                languageId = u.LanguageId;
                genreIds = u.GenreIds ?? new List<int>();
                tagIds = u.TagIds ?? new List<int>();
                personIds = u.PersonIds ?? new List<int>();
            }
            else if (dto is CreateTvShowDto c)
            {
                membershipId = c.MembershipId;
                languageId = c.LanguageId;
                genreIds = c.GenreIds ?? new List<int>();
                tagIds = c.TagIds ?? new List<int>();
                personIds = c.PersonIds ?? new List<int>();
            }

            ViewBag.Memberships = new SelectList(allMemberships, "Id", "Name", membershipId);
            ViewBag.Languages = new SelectList(allLanguages, "Id", "Name", languageId);
            ViewBag.Genres = new MultiSelectList(allGenres, "Id", "Name", genreIds);
            ViewBag.Tags = new MultiSelectList(allTags, "Id", "Name", tagIds);
            ViewBag.People = new MultiSelectList(allPeople, "Id", "Name", personIds);

            // Debug üçün raw JSON
            ViewBag.RawGenresJson = JsonConvert.SerializeObject(allGenres);
            ViewBag.RawTagsJson = JsonConvert.SerializeObject(allTags);
            ViewBag.RawPeopleJson = JsonConvert.SerializeObject(allPeople);
        }

        private static MultipartFormDataContent BuildMultipartContent(UpdateTvShowDto dto, bool isUpdate = false)
        {
            var content = new MultipartFormDataContent();

            if (isUpdate)
                content.Add(new StringContent(dto.Id.ToString()), "Id");

            content.Add(new StringContent(dto.Title ?? string.Empty), "Title");
            content.Add(new StringContent(dto.Status ?? string.Empty), "Status");
            content.Add(new StringContent(dto.Content ?? string.Empty), "Content");
            content.Add(new StringContent(dto.ReleaseDate.ToString("O")), "ReleaseDate");
            content.Add(new StringContent(dto.MembershipId.ToString()), "MembershipId");
            content.Add(new StringContent(dto.LanguageId.ToString()), "LanguageId");

            foreach (var id in dto.GenreIds ?? Enumerable.Empty<int>())
                content.Add(new StringContent(id.ToString()), "GenreIds");

            foreach (var id in dto.TagIds ?? Enumerable.Empty<int>())
                content.Add(new StringContent(id.ToString()), "TagIds");

            foreach (var id in dto.PersonIds ?? Enumerable.Empty<int>())
                content.Add(new StringContent(id.ToString()), "PersonIds");

            return content;
        }

        private static MultipartFormDataContent BuildMultipartContent(CreateTvShowDto dto)
        {
            var content = new MultipartFormDataContent();

            content.Add(new StringContent(dto.Title ?? string.Empty), "Title");
            content.Add(new StringContent(dto.Status ?? string.Empty), "Status");
            content.Add(new StringContent(dto.Content ?? string.Empty), "Content");
            content.Add(new StringContent(dto.ReleaseDate.ToString("O")), "ReleaseDate");
            content.Add(new StringContent(dto.MembershipId.ToString()), "MembershipId");
            content.Add(new StringContent(dto.LanguageId.ToString()), "LanguageId");

            foreach (var id in dto.GenreIds ?? Enumerable.Empty<int>())
                content.Add(new StringContent(id.ToString()), "GenreIds");

            foreach (var id in dto.TagIds ?? Enumerable.Empty<int>())
                content.Add(new StringContent(id.ToString()), "TagIds");

            foreach (var id in dto.PersonIds ?? Enumerable.Empty<int>())
                content.Add(new StringContent(id.ToString()), "PersonIds");

            return content;
        }

        #endregion
    }
}