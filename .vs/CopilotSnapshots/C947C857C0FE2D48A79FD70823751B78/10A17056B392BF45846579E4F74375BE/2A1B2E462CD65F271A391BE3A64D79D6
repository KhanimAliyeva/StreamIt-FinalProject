@model IEnumerable<STREAMIT.Business.Dtos.PersonDtos.GetPersonDto>

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Persons";
}

<div class="row">
    <div class="col-sm-12">
        <div class="streamit-wraper-table">
            <div class="card-header d-flex justify-content-between gap-3 flex-wrap align-items-center mb-4">
                <h2 class="episode-playlist-title wp-heading-inline">
                    <span class="position-relative">
                        Persons List
                    </span>
                </h2>

                <a asp-area="Admin"
                       asp-controller="Cast"
                       asp-action="Create"
                       class="btn btn-primary">
                    <i class="fa-solid fa-plus me-2"></i>
                    Add New
                </a>
            </div>

            <div class="table-view table-space">
                <table class="table custom-table movie_table">
                    <thead>
                        <tr class="text-uppercase">
                            <th></th>
                            <th>Image</th>
                            <th>Name</th>
                            <th>Born</th>
                            <th>Popularity</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var person in Model)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox" class="form-check-input" />
                                    </td>

                                    <td>
                                        <img src="@(!string.IsNullOrWhiteSpace(person.ImageUrl)
                                                                                                                                     ? person.ImageUrl
                                                                                                                                     : Url.Content("~/assets/images/author/ava-monroe.webp"))"
                                             class="rounded-2 avatar avatar-55 img-fluid"
                                             alt="person image" />
                                    </td>

                                    <td>@person.Name</td>

                                    <td>
                                        @(person.Born.HasValue
                                            ? person.Born.Value.ToString("yyyy-MM-dd")
                                            : "-")
                                    </td>

                                    <td>@person.Popularity</td>

                                    <td>
                                        <div class="d-flex gap-2">

                                            <!-- Edit -->
                                            <a asp-area="Admin"
                                                   asp-controller="Cast"
                                                   asp-action="Edit"
                                                   asp-route-id="@person.Id"
                                                   class="btn btn-sm btn-success">
                                                <i class="ph ph-pencil-simple"></i>
                                            </a>

                                            <!-- Details -->
                                            <a asp-area="Admin"
                                                   asp-controller="Cast"
                                                   asp-action="Details"
                                                   asp-route-id="@person.Id"
                                                   class="btn btn-sm btn-info">
                                                <i class="ph ph-eye"></i>
                                            </a>

                                            <!-- Delete -->
                                            <form asp-area="Admin"
                                                  asp-controller="Cast"
                                                  asp-action="Delete"
                                                  asp-route-id="@person.Id"
                                                  method="post"
                                                  class="d-inline"
                                                  onsubmit="return confirm('Are you sure you want to delete this person?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger">
                                                    <i class="ph ph-trash-simple"></i>
                                                </button>
                                            </form>

                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center">
                                    No persons found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>