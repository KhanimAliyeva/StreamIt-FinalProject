        await _emailService.SendEmailAsync(user.Email!, "Confirm your email", emailHtml);

        return View("EmailVerification"); // Email yoxlanışı üçün xüsusi view
    }

    // GET: /Account/ConfirmEmail
    [HttpGet]
    public async Task<IActionResult> ConfirmEmail(string userId, string token)
    {
        var user = await _userManager.FindByIdAsync(userId);

        if (user == null)
        {
            ViewBag.Message = "User not found";
            return View("ConfirmEmail");
        }

        token = WebUtility.UrlDecode(token);

        var result = await _userManager.ConfirmEmailAsync(user, token);

        ViewBag.Message = result.Succeeded ? "Email confirmed successfully" : "Email confirmation failed";
        return View("ConfirmEmail");
    }

    // POST: /Account/Logout
    [HttpPost]
    [ValidateAntiForgeryToken]
    public async Task<IActionResult> Logout()
    {
        await HttpContext.SignOutAsync(CookieAuthenticationDefaults.AuthenticationScheme);
        return RedirectToAction("Index", "Home");
    }

    // Helper: JWT claims-ləri çıxarmaq (istəsən login üçün istifadə oluna bilər)
    private IEnumerable<Claim> ExtractClaimsFromJwt(string jwt)
    {
        try
        {
            var handler = new JwtSecurityTokenHandler();
            var token = handler.ReadJwtToken(jwt);
            return token.Claims.Select(c => new Claim(c.Type, c.Value));
        }
        catch
        {
            return Array.Empty<Claim>();
        }
    }
}