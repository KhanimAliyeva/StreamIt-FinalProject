@model IEnumerable<STREAMIT.Business.Dtos.MovieDtos.GetMovieDto>

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="content-inner container-fluid pb-0" id="page_layout">
    <div class="row">
        <div class="col-sm-12">
            <div class="streamit-wraper-table">
                <div class="card-header d-flex justify-content-between gap-3 flex-wrap align-items-center mb-4">
                    <h2 class="episode-playlist-title wp-heading-inline">Movies</h2>
                    <a asp-area="Admin" asp-controller="Movie" asp-action="Create" class="btn btn-primary">
                        <i class="fa-solid fa-plus me-2"></i> Add Movie
                    </a>
                </div>

                <div class="table-view table-space">
                    <table id="seasonTable" class="table table-striped table-hover w-100">
                        <colgroup>
                            <col />
                            <col style="width:60px;" />
                            <col />
                            <col />
                            <col />
                            <col />
                            <col />
                            <col style="width:170px" />
                        </colgroup>
                        <thead>
                            <tr>
                                <th><input type="checkbox" class="form-check-input" /></th>
                                <th>Image</th>
                                <th>Title</th>
                                <th>Author</th>
                                <th>Date and Time</th>
                                <th>Views</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var movie in Model)
                                {
                                    <tr>
                                        <td><input type="checkbox" class="form-check-input" /></td>
                                        <td>
                                            <img src="@(string.IsNullOrWhiteSpace(movie.PosterUrl) ? Url.Content("~/admin/assets/images/movie-thumb/any-name.webp") : movie.PosterUrl)" alt="poster" class="rounded-2 avatar avatar-55 img-fluid" />
                                        </td>
                                        <td>@movie.Title</td>
                                        <td>@movie.MembershipName</td>
                                        <td>@movie.ReleaseDate.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@(movie.MovieStatistics?.ViewCount ?? 0)</td>
                                        <td>
                                            <input type="checkbox" class="form-check-input" disabled="disabled" @(movie.Status == "Published" ? "checked" : "") />
                                        </td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                <a asp-area="Admin" asp-controller="Movie" asp-action="Update" asp-route-id="@movie.Id" class="btn btn-sm btn-outline-primary" title="Edit">Edit</a>
                                                <form asp-area="Admin" asp-controller="Movie" asp-action="Delete" asp-route-id="@movie.Id" method="post" onsubmit="return confirm('Delete this movie?');" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                                </form>
                                                <a asp-area="Admin" asp-controller="Movie" asp-action="Update" asp-route-id="@movie.Id" class="btn btn-sm btn-outline-info" title="View">View</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center">No movies found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            if (window.jQuery && $.fn.dataTable) {
                $('#seasonTable').DataTable();
            }
        })();
    </script>
}
