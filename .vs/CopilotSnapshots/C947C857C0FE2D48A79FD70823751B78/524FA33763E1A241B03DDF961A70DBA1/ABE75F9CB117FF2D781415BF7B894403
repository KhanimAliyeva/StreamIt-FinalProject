@model STREAMIT.Business.Dtos.MovieDtos.CreateMovieDto
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <h2 class="mb-4">Add New Movie</h2>

    <form asp-area="Admin" asp-controller="Movie" asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">
            <div class="col-md-8">
                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Content" class="form-label"></label>
                    <textarea asp-for="Content" class="form-control" rows="6"></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="ReleaseDate" class="form-label"></label>
                        <input asp-for="ReleaseDate" type="datetime-local" class="form-control" />
                        <span asp-validation-for="ReleaseDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Duration" class="form-label"></label>
                        <input asp-for="Duration" type="number" step="0.1" class="form-control" />
                        <span asp-validation-for="Duration" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Imdb" class="form-label"></label>
                        <input asp-for="Imdb" type="number" step="0.1" class="form-control" />
                        <span asp-validation-for="Imdb" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="MembershipId" class="form-label"></label>
                        <select asp-for="MembershipId" class="form-select" asp-items="@(new SelectList(ViewBag.Memberships, "Id", "Name"))">
                            <option value="">-- Select Membership --</option>
                        </select>
                        <span asp-validation-for="MembershipId" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="LanguageId" class="form-label"></label>
                        <select asp-for="LanguageId" class="form-select" asp-items="@(new SelectList(ViewBag.Languages, "Id", "Name"))">
                            <option value="">-- Select Language --</option>
                        </select>
                        <span asp-validation-for="LanguageId" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Genres</label>
                    <select asp-for="GenreIds" asp-items="@(new SelectList(ViewBag.Genres, "Id", "Name"))" multiple class="form-select">
                    </select>
                    <span asp-validation-for="GenreIds" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Tags</label>
                    <select asp-for="TagIds" asp-items="@(new SelectList(ViewBag.Tags, "Id", "Name"))" multiple class="form-select">
                    </select>
                    <span asp-validation-for="TagIds" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">People (Cast/Crew)</label>
                    <select asp-for="PersonIds" asp-items="@(new SelectList(ViewBag.People, "Id", "FullName"))" multiple class="form-select">
                    </select>
                    <span asp-validation-for="PersonIds" class="text-danger"></span>
                </div>

            </div>

            <div class="col-md-4">
                <div class="mb-3">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select">
                        <option value="Published">Published</option>
                        <option value="Draft">Draft</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Poster" class="form-label">Poster</label>
                    <input asp-for="Poster" type="file" class="form-control" />
                    <span asp-validation-for="Poster" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Trailer" class="form-label">Trailer</label>
                    <input asp-for="Trailer" type="file" class="form-control" />
                    <span asp-validation-for="Trailer" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Movie" class="form-label">Movie File</label>
                    <input asp-for="Movie" type="file" class="form-control" />
                    <span asp-validation-for="Movie" class="text-danger"></span>
                </div>

            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-area="Admin" asp-controller="Movie" asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}
