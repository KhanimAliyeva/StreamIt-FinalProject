@model IEnumerable<STREAMIT.Business.Dtos.GenreDtos.GetGenreDto>

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Genres";
}

<div class="container-fluid py-4 d-flex flex-column min-vh-100">
    <!-- Header və Add Genre düyməsi -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Genres</h2>
        <a asp-action="Create" asp-controller="Genre" class="btn btn-primary">
            <i class="fa-solid fa-plus me-2"></i> Add Genre
        </a>
    </div>

    <!-- Table Card -->
    <div class="card flex-fill">
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 70vh; overflow-y: auto;">
                <table class="table table-striped table-hover w-100 mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Movies Count</th>
                            <th>TV Shows Count</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var genre in Model)
                            {
                                <tr>
                                    <td>@genre.Id</td>
                                    <td>@genre.Name</td>
                                    <td>@(genre.Movies?.Count ?? 0)</td>
                                    <td>@(genre.TvShows?.Count ?? 0)</td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-primary"
                                                    data-bs-toggle="offcanvas"
                                                    data-bs-target="#genre-offcanvas-edit-@genre.Id">
                                                <a asp-action="Edit" asp-route-id="@genre.Id" asp-controller="Genre">
                                                    Edit

                                                </a>
                                            </button>

                                            <form asp-area="Admin" asp-controller="Genre" asp-action="Delete" asp-route-id="@genre.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this genre?');" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                            </form>

                                        </div>

                                    
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center">No genres found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Footer (Layout içində də ola bilər, min-vh-100 ilə həmişə aşağıda) -->
</div>