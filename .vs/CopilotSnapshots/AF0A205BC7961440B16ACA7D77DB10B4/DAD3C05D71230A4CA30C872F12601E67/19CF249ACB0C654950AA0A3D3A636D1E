using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.SignalR;
using STREAMIT.DataAccess.Contexts;
using STREAMIT.Core.Entities;
using System.Security.Claims;

[AllowAnonymous]
public class CommunityHub : Hub
{
    private readonly AppDbContext _context;
    public CommunityHub(AppDbContext context) => _context = context;

    public async Task SendMessage(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return;

        var userId = Context.User?.FindFirstValue(ClaimTypes.NameIdentifier);
        var userName = Context.User?.Identity?.Name;

        // auth yoxdursa (AllowAnonymous) “User” yazırıq
        userName ??= "User";
        userId ??= "anonymous";

        var msg = new CommunityMessage
        {
            UserId = userId,
            Text = text.Trim(),
            SentAt = DateTime.UtcNow,
            GroupId = 1 // General (əgər groupId istifadə edirsənsə)
        };

        _context.CommunityMessages.Add(msg);
        await _context.SaveChangesAsync();

        await Clients.All.SendAsync("ReceiveMessage", new
        {
            userName,
            text = msg.Text,
            sentAt = msg.SentAt
        });
    }
}