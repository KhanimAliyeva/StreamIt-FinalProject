@{
    ViewData["Title"] = "Edit Profile";
}

<div class="iq-breadcrumb">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-sm-12">
                <nav aria-label="breadcrumb" class="text-center">
                    <ol class="breadcrumb justify-content-center text-white mt-0">
                        <li class="breadcrumb-item active">Your Profile</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="section-padding">
    <div class="pmpro container">
        <section class="pmpro_section">
            <div class="pmpro_section_content">

                <form id="profileForm" class="pmpro_form">
                    <div class="pmpro_card">
                        <div class="pmpro_card_content">

                            <fieldset class="pmpro_form_fieldset">
                                <legend class="pmpro_form_legend">
                                    <h2 class="pmpro_form_heading pmpro_font-large">Account Information</h2>
                                </legend>

                                <div class="pmpro_form_fields pmpro_cols-2">

                                    <div class="pmpro_form_field">
                                        <label class="pmpro_form_label">Full Name</label>
                                        <input type="text" id="fullName"
                                               class="pmpro_form_input pmpro_form_input-text"
                                               placeholder="Full name">
                                    </div>

                                    <div class="pmpro_form_field">
                                        <label class="pmpro_form_label">Username</label>
                                        <input type="text" id="userName"
                                               class="pmpro_form_input pmpro_form_input-text"
                                               placeholder="Username">
                                    </div>

                                    <div class="pmpro_form_field">
                                        <label class="pmpro_form_label">Email</label>
                                        <input type="email" id="email"
                                               class="pmpro_form_input pmpro_form_input-email"
                                               placeholder="Email">
                                    </div>

                                </div>
                            </fieldset>

                            <div class="pmpro_form_submit">
                                <button type="submit" class="pmpro_btn pmpro_btn-submit-update-profile">
                                    Update Profile
                                </button>

                                <a href="/" class="pmpro_btn pmpro_btn-cancel">Cancel</a>
                            </div>

                            <div id="profileMsg" class="mt-3"></div>

                        </div>
                    </div>
                </form>

            </div>
        </section>
    </div>
</div>

<script>
    // 1) səhifə açılan kimi məlumatı MVC controller-dən çək
    document.addEventListener("DOMContentLoaded", async () => {
      const msg = document.getElementById("profileMsg");
      msg.innerHTML = "";

      const resp = await fetch("/Profile/Me");

      if(resp.status === 401){
        window.location.href = "/Account/Login?returnUrl=" + encodeURIComponent(location.pathname + location.search);
        return;
      }

      if(!resp.ok){
        msg.innerHTML = `<div class="alert alert-danger">Load failed: ${resp.status}</div>`;
        return;
      }

      const user = await resp.json();

      document.getElementById("fullName").value = user.fullName ?? "";
      document.getElementById("userName").value = user.userName ?? "";
      document.getElementById("email").value = user.email ?? "";
    });

    // 2) Save
    document.getElementById("profileForm").addEventListener("submit", async (e) => {
      e.preventDefault();

      const msg = document.getElementById("profileMsg");
      msg.innerHTML = "";

      const payload = {
        fullName: document.getElementById("fullName").value,
        userName: document.getElementById("userName").value,
        email: document.getElementById("email").value
      };

      const resp = await fetch("/Profile/Update", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });

      if(resp.status === 401){
        window.location.href = "/Account/Login?returnUrl=" + encodeURIComponent(location.pathname + location.search);
        return;
      }

      if(!resp.ok){
        const txt = await resp.text();
        msg.innerHTML = `<div class="alert alert-danger">Update failed: ${txt}</div>`;
        return;
      }

    msg.innerHTML = `<div class="alert alert-success">Profile updated ✅</div>`;
    setTimeout(() => {
      window.location.href = "/Profile";   // profil index-ə qayıt
    }, 500);
   });
</script>