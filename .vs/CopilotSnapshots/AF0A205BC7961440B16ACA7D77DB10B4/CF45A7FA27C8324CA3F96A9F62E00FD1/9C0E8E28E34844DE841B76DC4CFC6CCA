@model IEnumerable<STREAMIT.Business.Dtos.UserDtos.GetUserDto>

<div class="table-view table-space">
    <table id="userTable" class="table custom-table movie_table">
        <thead>
            <tr class="text-uppercase">
                <th style="width:80px;">Profile</th>
                <th>Name</th>
                <th>Email</th>
                <th style="width:120px;">Role</th>
                <th style="width:140px;">Membership</th>
                <th style="width:100px;">Favorites</th>
                <th style="width:100px;">Reviews</th>
                <th style="width:100px;">Status</th>
                <th style="width:120px;">Join Date</th>
                <th style="width:140px;">Actions</th>
            </tr>
        </thead>

        <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var u in Model)
                        {
                            var favoritesTotal = u.FavoriteMoviesCount;
                            var reviewsTotal = u.MovieReviewsCount;

                            <tr>
                                <td>
                                    <img src="@(string.IsNullOrWhiteSpace(u.ProfilePictureUrl) ? Url.Content("~/assets/images/author/ava-monroe.webp") : u.ProfilePictureUrl)"
                                         class="rounded-2 avatar avatar-55 img-fluid"
                                         alt="@(string.IsNullOrWhiteSpace(u.Fullname) ? u.UserName : u.Fullname)" />
                                </td>

                                <td>@(string.IsNullOrWhiteSpace(u.Fullname) ? u.UserName : u.Fullname)</td>
                                <td>@u.Email</td>
                                <td>@(string.IsNullOrWhiteSpace(u.Role) ? "—" : u.Role)</td>
                                <td>@(string.IsNullOrWhiteSpace(u.MembershipName) ? "None" : u.MembershipName)</td>
                                <td>@favoritesTotal</td>
                                <td>@reviewsTotal</td>

                                <td>
                                    @if (u.EmailConfirmed)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                </td>

                                <td>@(u.CreatedAt == default ? "—" : u.CreatedAt.ToString("yyyy-MM-dd"))</td>

                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-area="Admin" asp-controller="User" asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary">Edit</a>

                                        <form asp-area="Admin" asp-controller="User" asp-action="Delete" asp-route-id="@u.Id" method="post" onsubmit="return confirm('Are you sure to delete this user?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                        </form>

                                        <a asp-area="Admin" asp-controller="User" asp-action="Details" asp-route-id="@u.Id" class="btn btn-sm btn-outline-info">Details</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
            else
            {
                <tr>
                    <td colspan="9" class="text-center">No users found.</td>
                </tr>
            }
        </tbody>

        <tfoot>
            <tr class="text-uppercase">
                <th>Profile</th>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Membership</th>
                <th>Favorites</th>
                <th>Reviews</th>
                <th>Status</th>
                <th>Join Date</th>
            </tr>
        </tfoot>
    </table>
</div>