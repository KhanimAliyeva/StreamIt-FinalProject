using Microsoft.AspNetCore.Http;
using Microsoft.AspNetCore.Mvc;
using Microsoft.AspNetCore.Mvc.Rendering;
using STREAMIT.Business.Dtos;
using STREAMIT.Business.Dtos.GenreDtos;
using STREAMIT.Business.Dtos.LanguageDtos;
using STREAMIT.Business.Dtos.MembershipDtos;
using STREAMIT.Business.Dtos.MovieDtos;
using STREAMIT.Business.Dtos.PersonDtos;
using STREAMIT.Business.Dtos.ResultDtos;
using STREAMIT.Business.Dtos.TagDtos;
using System.Collections.Generic;
using System.Linq;
using System.Net.Http.Headers;
using System.Net.Http.Json;

namespace STREAMIT.MVC.Areas.Admin.Controllers;

[Area("Admin")]
public class MovieController : Controller
{
    private readonly HttpClient _httpClient;

    public MovieController(IHttpClientFactory httpClientFactory)
    {
        _httpClient = httpClientFactory.CreateClient("ApiClient");
    }

    private static MultipartFormDataContent BuildMultipartContent(UpdateMovieDto dto, bool isUpdate = false)
    {
        var content = new MultipartFormDataContent();

        if (isUpdate)
            content.Add(new StringContent(dto.Id.ToString()), "Id");

        content.Add(new StringContent(dto.Title ?? string.Empty), "Title");
        content.Add(new StringContent(dto.Status ?? string.Empty), "Status");
        content.Add(new StringContent(dto.Content ?? string.Empty), "Content");
        content.Add(new StringContent(dto.ReleaseDate.ToString("O")), "ReleaseDate");
        content.Add(new StringContent(dto.Duration.ToString()), "Duration");
        content.Add(new StringContent(dto.MembershipId.ToString()), "MembershipId");
        content.Add(new StringContent(dto.LanguageId.ToString()), "LanguageId");

        foreach (var genreId in dto.GenreIds ?? Enumerable.Empty<int>())
            content.Add(new StringContent(genreId.ToString()), "GenreIds");

        foreach (var tagId in dto.TagIds ?? Enumerable.Empty<int>())
            content.Add(new StringContent(tagId.ToString()), "TagIds");

        foreach (var personId in dto.PersonIds ?? Enumerable.Empty<int>())
            content.Add(new StringContent(personId.ToString()), "PersonIds");

        if (dto.Poster != null)
            AddFile(content, dto.Poster, "Poster");

        if (!string.IsNullOrWhiteSpace(dto.YoutubeUrl))
            content.Add(new StringContent(dto.YoutubeUrl), "YoutubeUrl");

        if (dto.Movie != null)
            AddFile(content, dto.Movie, "Movie");

        return content;
    }

    #region INDEX
    public async Task<IActionResult> Index()
    {
        var movies = await SafeGetFromJson<List<GetMovieDto>>("Movie");
        return View(movies ?? new List<GetMovieDto>());
    }
    #endregion

    #region DELETE
    public async Task<IActionResult> Delete(int id)
    {
        var response = await _httpClient.DeleteAsync($"Movie/{id}");
        if (!response.IsSuccessStatusCode)
        {
            var error = await SafeReadJson<ResultDto>(response);
            return NotFound(error?.Message ?? "Something went wrong...");
        }
        return RedirectToAction(nameof(Index));
    }
    #endregion

    #region CREATE
    public async Task<IActionResult> Create()
    {
        await LoadDropdowns();
        // return initialized model so multi-selects have non-null lists
        return View(new CreateMovieDto());
    }

    [HttpPost]
    [ValidateAntiForgeryToken]
    public async Task<IActionResult> Create(CreateMovieDto dto)
    {
        if (!ModelState.IsValid)
        {
            await LoadDropdowns();
            return View(dto);
        }

        using var content = BuildMultipartContent(dto);

        var response = await _httpClient.PostAsync("Movie", content);
        var respText = await response.Content.ReadAsStringAsync();
        if (!response.IsSuccessStatusCode)
        {
            await LoadDropdowns();
            // Try to parse structured error, otherwise show raw response
            var error = await SafeReadJson<ResultDto>(response);
            var message = error?.Message ?? respText;
            ModelState.AddModelError(string.Empty, message ?? "Something went wrong...");
            ViewBag.ApiErrors = (ViewBag.ApiErrors as List<string> ?? new List<string>());
            ((List<string>)ViewBag.ApiErrors).Add($"Create failed: {message}");
            return View(dto);
        }

        // success — include response body in TempData for debugging (can be removed later)
        TempData["ApiResponse"] = respText;
        return RedirectToAction(nameof(Index));
    }
    #endregion

    #region UPDATE
    public async Task<IActionResult> Update(int id)
    {
        // Get full movie details
        var movie = await SafeGetFromJson<GetMovieDto>($"Movie/{id}");
        if (movie == null) return BadRequest();

        // Load dropdowns (memberships, languages, genres, tags, people)
        await LoadDropdowns();

        // Build UpdateMovieDto from GetMovieDto
        var dto = new UpdateMovieDto
        {
            Id = movie.Id,
            Title = movie.Title,
            Content = movie.Content,
            ReleaseDate = movie.ReleaseDate,
            Duration = movie.Duration,
            Status = movie.Status,
            YoutubeUrl = movie.YoutubeUrl
        };

        // Genres & People include IDs in GetMovieDto
        dto.GenreIds = movie.Genres?.Select(g => g.Id).ToList() ?? new List<int>();
        dto.PersonIds = movie.People?.Select(p => p.Id).ToList() ?? new List<int>();

        // Resolve TagIds by matching tag names to tags from API
        var allTags = await GetListSafe<TagDto>("Tag");
        dto.TagIds = movie.Tags?
            .Select(tn => allTags.FirstOrDefault(a => a.Name == tn)?.Id)
            .Where(id => id != null)
            .Select(id => id!.Value)
            .ToList() ?? new List<int>();

        // Resolve MembershipId and LanguageId by matching names
        var allMemberships = await GetListSafe<MembershipDto>("Membership");
        var mem = allMemberships.FirstOrDefault(m => m.Name == movie.MembershipName);
        dto.MembershipId = mem?.Id ?? 0;

        var allLanguages = await GetListSafe<LanguageDto>("Language");
        var lang = allLanguages.FirstOrDefault(l => l.Name == movie.LanguageName);
        dto.LanguageId = lang?.Id ?? 0;

        // Recreate SelectLists with selected values so tag helpers mark the chosen options
        ViewBag.Memberships = new SelectList(allMemberships ?? new List<MembershipDto>(), "Id", "Name", dto.MembershipId);
        ViewBag.Languages = new SelectList(allLanguages ?? new List<LanguageDto>(), "Id", "Name", dto.LanguageId);

        var allGenres = await GetListSafe<GenreDto>("Genre");
        ViewBag.Genres = new SelectList(allGenres ?? new List<GenreDto>(), "Id", "Name", dto.GenreIds);

        ViewBag.Tags = new SelectList(allTags ?? new List<TagDto>(), "Id", "Name", dto.TagIds);

        var allPeople = await GetListSafe<PersonDto>("Person");
        ViewBag.People = new SelectList(allPeople ?? new List<PersonDto>(), "Id", "FullName", dto.PersonIds);

        return View(dto);
    }

    [HttpPost]
    [ValidateAntiForgeryToken]
    public async Task<IActionResult> Update(UpdateMovieDto dto)
    {
        if (!ModelState.IsValid)
        {
            await LoadDropdowns();
            return View(dto);
        }

        using var content = BuildMultipartContent(dto, isUpdate: true);

        var response = await _httpClient.PutAsync($"Movie/{dto.Id}", content);
        if (!response.IsSuccessStatusCode)
        {
            await LoadDropdowns();
            var error = await SafeReadJson<ResultDto>(response);
            ModelState.AddModelError(string.Empty, error?.Message ?? "Something went wrong...");
            return View(dto);
        }

        return RedirectToAction(nameof(Index));
    }
    #endregion

    public async Task<IActionResult> Details(int id)
    {
        var result = await SafeGetFromJson<ResultDto<GetMovieDto>>($"Movie/{id}");
        if (result == null) return BadRequest();
        return View(result.Data);
    }

    #region HELPERS

    private static MultipartFormDataContent BuildMultipartContent(CreateMovieDto dto, bool isUpdate = false)
    {
        var content = new MultipartFormDataContent();

        if (isUpdate)
        {
            // If update DTO contains Id, add it. CreateMovieDto doesn't include Id.
        }

        content.Add(new StringContent(dto.Title ?? string.Empty), "Title");
        content.Add(new StringContent(dto.Status ?? string.Empty), "Status");
        content.Add(new StringContent(dto.Content ?? string.Empty), "Content");
        content.Add(new StringContent(dto.ReleaseDate.ToString("O")), "ReleaseDate");
        content.Add(new StringContent(dto.Duration.ToString()), "Duration");
        content.Add(new StringContent(dto.MembershipId.ToString()), "MembershipId");
        content.Add(new StringContent(dto.LanguageId.ToString()), "LanguageId");

        foreach (var genreId in dto.GenreIds ?? Enumerable.Empty<int>())
            content.Add(new StringContent(genreId.ToString()), "GenreIds");

        foreach (var tagId in dto.TagIds ?? Enumerable.Empty<int>())
            content.Add(new StringContent(tagId.ToString()), "TagIds");

        foreach (var personId in dto.PersonIds ?? Enumerable.Empty<int>())
            content.Add(new StringContent(personId.ToString()), "PersonIds");

        if (dto.Poster != null)
            AddFile(content, dto.Poster, "Poster");

        if (!string.IsNullOrWhiteSpace(dto.YoutubeUrl))
            content.Add(new StringContent(dto.YoutubeUrl), "YoutubeUrl");

        if (dto.Movie != null)
            AddFile(content, dto.Movie, "Movie");

        return content;
    }

    private static void AddFile(MultipartFormDataContent content, IFormFile file, string name)
    {
        var streamContent = new StreamContent(file.OpenReadStream());
        streamContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType ?? "application/octet-stream");
        content.Add(streamContent, name, file.FileName);
    }

    private async Task LoadDropdowns()
    {
        ViewBag.Memberships = (await GetListSafe<MembershipDto>("Membership"))
            .Select(x => new SelectListItem
            {
                Text = x.Name,
                Value = x.Id.ToString()
            }).ToList();

        ViewBag.Languages = (await GetListSafe<LanguageDto>("Language"))
            .Select(x => new SelectListItem
            {
                Text = x.Name,
                Value = x.Id.ToString()
            }).ToList();

        ViewBag.Genres = (await GetListSafe<GenreDto>("Genre"))
            .Select(x => new SelectListItem
            {
                Text = x.Name,
                Value = x.Id.ToString()
            }).ToList();

        ViewBag.Tags = (await GetListSafe<TagDto>("Tag"))
            .Select(x => new SelectListItem
            {
                Text = x.Name,
                Value = x.Id.ToString()
            }).ToList();

        ViewBag.People = (await GetListSafe<PersonDto>("Person"))
            .Select(x => new SelectListItem
            {
                Text = x.Name,
                Value = x.Id.ToString()
            }).ToList();
    }
    private async Task<List<T>> GetListSafe<T>(string endpoint)
    {
        // Try ResultDto<List<T>> first
        var resultDto = await SafeGetFromJson<ResultDto<List<T>>>(endpoint);
        if (resultDto != null) return resultDto.Data ?? new List<T>();

        // Fallback to List<T>
        var rawList = await SafeGetFromJson<List<T>>(endpoint);
        if (rawList != null) return rawList;

        // Couldn't load data for this endpoint — record it for diagnostics and return empty list
        var errors = ViewBag.ApiErrors as List<string> ?? new List<string>();
        errors.Add($"Failed to load '{endpoint}' from API.");
        ViewBag.ApiErrors = errors;

        return new List<T>();
    }

    private async Task<T?> SafeGetFromJson<T>(string endpoint)
    {
        try
        {
            var response = await _httpClient.GetAsync(endpoint);
            if (!response.IsSuccessStatusCode) return default;
            return await response.Content.ReadFromJsonAsync<T>();
        }
        catch
        {
            return default;
        }
    }

    private async Task<T?> SafeReadJson<T>(HttpResponseMessage response)
    {
        try
        {
            return await response.Content.ReadFromJsonAsync<T>();
        }
        catch
        {
            return default;
        }
    }

    #endregion
}
