@model STREAMIT.Business.Dtos.MovieDtos.CreateMovieDto
@using Microsoft.AspNetCore.Mvc.Rendering
@using STREAMIT.Business.Dtos.MembershipDtos
@using STREAMIT.Business.Dtos.PersonDtos
@using STREAMIT.Business.Dtos.TagDtos


<div class="container py-5">
    <h2 class="mb-4 text-primary">Add New Movie</h2>

    <form asp-area="Admin" asp-controller="Movie" asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">

            <!-- Left Column: Movie Details -->
            <div class="col-lg-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Movie Info</h5>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Title</label>
                            <input asp-for="Title" class="form-control" placeholder="Enter movie title" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Content" class="form-label">Content</label>
                            <textarea asp-for="Content" class="form-control" rows="6" placeholder="Movie description..."></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="ReleaseDate" class="form-label">Release Date</label>
                                <input asp-for="ReleaseDate" type="datetime-local" class="form-control" />
                                <span asp-validation-for="ReleaseDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Duration" class="form-label">Duration</label>
                                <input asp-for="Duration" type="number" step="0.1" placeholder="0.0" class="form-control" />
                                <span asp-validation-for="Duration" class="text-danger"></span>
                            </div>
                       
                        </div>

                        <div class="row g-3 mt-3">
                            <div class="col-md-6">
                                <label asp-for="MembershipId" class="form-label"></label>
                                <select asp-for="MembershipId" class="form-select" asp-items="@(new SelectList(ViewBag.Memberships ?? new List<MembershipDto>(), "Id", "Name"))">
                                    <option value="">-- Select Membership --</option>
                                </select>
                                <span asp-validation-for="MembershipId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LanguageId" class="form-label"></label>
                                <select asp-for="LanguageId" class="form-select" asp-items="@(new SelectList(ViewBag.Languages ?? new List<LanguageDto>(), "Id", "Name"))">
                                    <option value="">-- Select Language --</option>
                                </select>
                                <span asp-validation-for="LanguageId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-3">
                            <div class="col-md-6">
                                <label class="form-label">Genres</label>
                                <select asp-for="GenreIds" asp-items="@(new SelectList(ViewBag.Genres, "Id", "Name"))" multiple class="form-select">
                                </select>
                                <span asp-validation-for="GenreIds" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Tags</label>
                                <select asp-for="TagIds" asp-items="@(new SelectList(ViewBag.Tags ?? new List<TagDto>(), "Id", "Name"))" multiple class="form-select"></select>

                                <span asp-validation-for="TagIds" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-3">
                            <label class="form-label">People (Cast/Crew)</label>
                            <select asp-for="PersonIds" asp-items="@(new SelectList(ViewBag.People ?? new List<PersonDto>(), "Id", "FullName"))" multiple class="form-select"></select>
      
                            <span asp-validation-for="PersonIds" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Files & Status -->
            <div class="col-lg-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Media & Status</h5>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Published">Published</option>
                                <option value="Draft">Draft</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Poster" class="form-label">Poster</label>
                            <input asp-for="Poster" type="file" class="form-control" />
                            <span asp-validation-for="Poster" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="YoutubeUrl" class="form-label">YouTube URL</label>
                            <input asp-for="YoutubeUrl" type="text" class="form-control" />
                            <span asp-validation-for="YoutubeUrl" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Movie" class="form-label">Movie File</label>
                            <input asp-for="Movie" type="file" class="form-control" />
                            <span asp-validation-for="Movie" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="offcanvas-footer border-top">
            <div class="d-flex gap-3 p-3">
                <button type="submit" class="btn btn-primary d-flex align-items-center gap-2">
                    <i class="ph-fill ph-floppy-disk-back"></i>Save
                </button>
                <button type="button" class="btn btn-outline-primary d-flex align-items-center gap-2" data-bs-dismiss="offcanvas"
                        aria-label="Close">
                    <i class="ph ph-caret-double-left"></i>Close
                </button>
            </div>
        </div>
    </form>
</div>
