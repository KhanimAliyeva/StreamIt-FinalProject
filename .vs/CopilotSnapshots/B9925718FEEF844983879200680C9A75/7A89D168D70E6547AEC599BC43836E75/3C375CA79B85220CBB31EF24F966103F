                </div>
            </div>
        </div>
        <!-- Upcoming End -->

        <div class="section-padding-bottom">
            <div class="rate-review-details">
                <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                    <h5 class="main-title text-capitalize m-0 fw-medium">Review</h5>
                    <div class="d-flex align-items-center gap-3">
                        <a id="openReviewButton" class="btn btn-link p-0 custom-fs-14 openReviewButton" data-bs-toggle="offcanvas"
                               href="#offcanvasReview" role="button" aria-controls="offcanvasReview">
                            Add Review
                        </a>
                        <a class="btn btn-link p-0 custom-fs-14" href="./view-more.html">View More</a>
                    </div>
                </div>
                <div class="comments-section">
                    <!-- Existing reviews will be rendered here dynamically -->
                    @if (!Model.Reviews.Any())
                    {
                        <p class="text-muted">No reviews available.</p>
                    }
                    
                        
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="review-card">
                            <div class="review-detail rounded-3">
                                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                                    <div class="d-flex align-items-center justify-content-center gap-3">
                                        <img src="@review.User!.ProfilePictureUrl" class="img-fluid user-img rounded-circle" alt="@review.User.UserName">
                                        <div>
                                            <h6 class="line-count-1 m-0">@review.User.UserName</h6>
                                            <p class="mb-0 mt-1 small-date-font">@review.CreatedDate.ToString("yyyy-MM-dd HH:mm")</p>
                                        </div>
                                    </div>

                                    <div class="star-rating" data-rating="@review.Rating">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= review.Rating)
                                            {
                                                <i class="ph-fill ph-star text-warning"></i>
                                            }
                                            else
                                            {
                                                <i class="ph-fill ph-star"></i>
                                            }
                                        }
                                    </div>
                                </div>

                                <p class="mb-0 mt-3 pt-3 border-top fw-medium">@review.Comment</p>
                            </div>
                        </div>
                    }
                
                    
                </div>
            </div>

            <!-- Offcanvas review form -->
            <div class="offcanvas overflow-y-auto widget-shopping-cart-content offcanvas-end offcanvas-sidebar sidebar-container on-rtl end border-left-0"
                 tabindex="-1" id="offcanvasReview" aria-modal="true" role="dialog">
                <div class="offcanvas-header position-relative border-bottom">
                    <h5 class="offcanvas-title fw-500" id="offcanvasReviewLabel">
                        Add Review
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body">
                    <form asp-action="AddReview" method="post">
                        <!-- Hidden fields -->
                        <input type="hidden" name="MovieId" value="@Model.Id" />
                        <input type="hidden" name="UserId" value="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value" />

                        <!-- Rating section -->
                        <div class="form-group mb-4">
                            <label class="form-label mb-3">Your Rating</label>
                            <div class="star-rating" id="starRating">
                                <input type="radio" id="star5" name="Rating" value="5">
                                <label for="star5" title="5 stars"><i class="ph-fill ph-star"></i></label>
                                <input type="radio" id="star4" name="Rating" value="4">
                                <label for="star4" title="4 stars"><i class="ph-fill ph-star"></i></label>
                                <input type="radio" id="star3" name="Rating" value="3">
                                <label for="star3" title="3 stars"><i class="ph-fill ph-star"></i></label>
                                <input type="radio" id="star2" name="Rating" value="2">
                                <label for="star2" title="2 stars"><i class="ph-fill ph-star"></i></label>
                                <input type="radio" id="star1" name="Rating" value="1">
                                <label for="star1" title="1 star"><i class="ph-fill ph-star"></i></label>
                            </div>
                        </div>

                        <!-- Comment -->
                        <div class="form-group">
                            <label class="form-label flex-grow-1" for="Comment">
                                Your Review
                            </label>
                            <textarea id="Comment" name="Comment" class="form-control review-text-area" rows="8"></textarea>
                        </div>

                        <!-- Submit button -->
                        <div class="iq-button">
                            <button type="submit" class="btn btn-primary text-capitalize">
                                <span class="button-text">Submit Review</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade view-more-data-modal trending-info" id="viewMoreDataModal" tabindex="-1" aria-modal="true"
     role="dialog">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header pb-0">
                <h3 class="text-uppercase m-0 texture-text texture-text-modal fw-bold">@Model.Title</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-1">
                <ul class="list-inline d-flex align-items-center flex-wrap gap-3 mt-4">
                    <li>
                        <span class="fw-medium">@Model.ReleaseDate.Year</span>
                    </li>
                    <li>
                        <span class="d-flex align-items-center gap-1">
                            <i class="icon-eye-2"></i> @Model.MovieStatistics!.ViewCount views
                        </span>
                    </li>
                    <li>
                        <span class="d-flex align-items-center gap-1">
                            <span class="fw-medium">5</span>
                            <span class="imdb-logo ms-1">
                                <img src="./assets/images/pages/imdb-logo.svg" loading="lazy" decoding="async"
                                     alt="imdb logo" class="img-fluid imdb-logo1">
                            </span>
                        </span>
                    </li>
                </ul>

                <div class="d-flex align-items-baseline flex-wrap gap-2 mt-md-1 mt-2">
                    <h6 class="m-0">Genres:</h6>
                    <ul class="p-0 mb-0 list-inline d-flex flex-wrap movie-tag">
                        @foreach (var genre in Model.Genres)
                        {
                            <li class="trending-list">
                                <a href="./view-all-movie.html">@genre.Name</a>
                            </li>
                        }
                        
                    </ul>
                </div>

                <div class="d-flex align-items-baseline flex-wrap gap-2 mt-3">
                    <h6 class="m-0">Tags:</h6>
                    <ul class="iq-blog-meta-cat-tag iq-blogtag mb-0 list-inline d-flex flex-wrap align-items-center gap-1 gap-md-3 mt-2 mt-md-3  tvshow-tags">
                      
                        @foreach (var tag in Model.Tags)
                        {
                            <li>
                                @* <a href="./blog/blog-tag.html" class="position-relative">@tag.</a> *@
                            </li>
                        }
                      
                    </ul>
                </div>

                <div class="mt-4">
                    <div class="d-flex align-items-center gap-1">
                        <i class="icon-translate"></i>
                        <ul class="list-inline m-0 d-inline-flex align-items-center gap-2">
                            <li><small>@Model.LanguageName</small></li>
                        </ul>
                    </div>
                </div>

                <p class="mt-4 mb-0">
                    @Model.Content
                </p>

                <div class="d-flex align-items-baseline row-gap-1 column-gap-2 mt-4">
                    <h6 class="m-0">Cast:</h6>
                    <ul class="list-inline m-0 p-0 d-flex align-items-center flex-wrap row-gap-1 column-gap-2 cast-crew-list">
                        @foreach (var person in Model.People)
                        {
                            <li><a href="#" class="color-inherit">@person.Name</a></li>
                        }
                    </ul>
                </div>

            
            </div>
        </div>
    </div>
</div>
