using Microsoft.Extensions.Configuration;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Options;
using STREAMIT.Business.Dtos.KapitalBankOptionsDtos;
using STREAMIT.Business.Dtos.PaymentDtos;
using STREAMIT.Business.Services.Abstractions;
using STREAMIT.Core.Entities;
using STREAMIT.DataAccess.Contexts;
using System;
using System.Collections.Generic;
using System.Net.Http.Headers;
using System.Text;
using System.Text.Json;

namespace STREAMIT.Business.Services.Implementations
{
    public class KapitalBankPaymentService : IPaymentService
    {
        private readonly HttpClient httpClient;
        private readonly KapitalBankOptions _optionsVM;
        private readonly ILogger<KapitalBankPaymentService> _logger;


        public KapitalBankPaymentService(HttpClient httpClient, IConfiguration configuration, ILogger<KapitalBankPaymentService> logger)
        {
            this.httpClient = httpClient;
            _logger = logger;

            _optionsVM = configuration.GetSection("KapitalBankOptions").Get<KapitalBankOptions>() ?? new();
        }


        public async Task<PurchaseVM> CreatePaymentAsync(MembershipCreateVM vm)
        {
            // payload matching the curl example (amount as string to match the sample)
            var payload = new
            {
                order = new
                {
                    typeRid = "Order_SMS",
                    amount = vm.Amount.ToString().Replace(",", "."),
                    currency = vm.Currency,
                    language = "az",
                    description = vm.Description,
                    hppRedirectUrl = vm.RedirectUrl,
                    hppCofCapturePurposes = new[] { "Cit" }
                }
            };

            var options = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
            var json = JsonSerializer.Serialize(payload, options);

            using var request = new HttpRequestMessage(HttpMethod.Post, "https://txpgtst.kapitalbank.az/api/order/");
            request.Content = new StringContent(json, Encoding.UTF8, "application/json");

            var username = _optionsVM.Username;
            var password = _optionsVM.Password;
            var basicValue = Convert.ToBase64String(Encoding.UTF8.GetBytes($"{username}:{password}"));
            request.Headers.Authorization = new AuthenticationHeaderValue("Basic", basicValue);

            using var response = await httpClient.SendAsync(request);
            var content = await response.Content.ReadAsStringAsync();

            if (!response.IsSuccessStatusCode)
            {
                throw new InvalidOperationException($"Payment request failed: {response.StatusCode} - {content}");
            }


            var result = Newtonsoft.Json.JsonConvert.DeserializeObject<PurchaseVM>(content);

            if (result != null && result.Membership != null)
                return result;

            // Fallback: try to parse response dynamically and map common fields (hppUrl, password, id)
            try
            {
                _logger?.LogWarning("PurchaseVM deserialization returned null or missing Membership. Attempting fallback mapping.");

                var jo = Newtonsoft.Json.Linq.JObject.Parse(content);

                // find tokens by name (case-insensitive)
                string? hppUrl = null;
                string? password = null;
                int id = 0;

                foreach (var prop in jo.Descendants().OfType<Newtonsoft.Json.Linq.JProperty>())
                {
                    var name = prop.Name ?? string.Empty;
                    var val = prop.Value.Type == Newtonsoft.Json.Linq.JTokenType.String ? prop.Value.ToString() : null;

                    if (string.IsNullOrEmpty(hppUrl) && name.Equals("hppUrl", System.StringComparison.OrdinalIgnoreCase))
                        hppUrl = val;
                    if (string.IsNullOrEmpty(hppUrl) && name.IndexOf("hpp", System.StringComparison.OrdinalIgnoreCase) >= 0 && !string.IsNullOrEmpty(val))
                        hppUrl = val;

                    if (string.IsNullOrEmpty(password) && name.Equals("password", System.StringComparison.OrdinalIgnoreCase))
                        password = val;

                    if (id == 0 && name.Equals("id", System.StringComparison.OrdinalIgnoreCase))
                    {
                        if (int.TryParse(prop.Value.ToString(), out var parsed))
                            id = parsed;
                    }
                }

                if (!string.IsNullOrEmpty(hppUrl))
                {
                    var purchase = new PurchaseVM
                    {
                        Membership = new STREAMIT.Business.Dtos.PaymentDtos.MembershipGetVM
                        {
                            HppUrl = hppUrl,
                            Password = password ?? string.Empty,
                            Id = id
                        }
                    };

                    _logger?.LogInformation("Mapped payment provider response to PurchaseVM via fallback mapping.");
                    return purchase;
                }
            }
            catch (System.Exception ex)
            {
                _logger?.LogError(ex, "Fallback mapping failed while parsing payment provider response.");
            }

            // Log full content to help debugging why deserialization didn't produce expected object
            _logger?.LogError("Unexpected payment provider response. Content: {Content}", content);
            throw new InvalidOperationException($"Unexpected payment provider response. Content: {content}");





        }
        public async Task<string> GetPaymentStatusAsync(string orderId)
        {
            return "FullyPaid"; // test üçün
        }

    
    }
}
